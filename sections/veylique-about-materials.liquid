        { "type": "material", "settings": { "fallback": "about-ingredient-blue-tansy.jpg", "tag": "III", "name": "Viscose Crepe", "desc": "Fluid, drapey, and crease-friendly, selected for pieces that need to move from desk to dinner." } },
