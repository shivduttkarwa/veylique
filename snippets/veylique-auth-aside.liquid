{% doc %}
  Renders the editorial brand panel shown alongside customer account forms
  (login, register, reset and activate password).

  @param {image} [image] - Merchant-selected panel image.
  @param {string} [fallback] - Asset filename used when no image is selected.
  @param {string} [eyebrow] - Small mono eyebrow above the headline.
  @param {string} [heading] - Display headline.
  @param {string} [text] - Supporting paragraph.

  @example
  {% render 'veylique-auth-aside',
    image: section.settings.image,
    fallback: 'hero-3.webp',
    eyebrow: 'Veylique',
    heading: section.settings.aside_heading,
    text: section.settings.aside_text
  %}
{% enddoc %}

<aside class="vq-auth__aside" aria-hidden="true">
  <div class="vq-auth__aside-media">
    {% render 'veylique-responsive-image',
      image: image,
      fallback: fallback,
      class: '',
      alt: heading,
      loading: 'eager',
      width: 1600,
      height: 2000
    %}
  </div>
  <div class="vq-auth__aside-inner">
    {% if eyebrow != blank %}
      <p class="vq-auth__aside-eyebrow">{{ eyebrow | escape }}</p>
    {% endif %}
    {% if heading != blank %}
      <p class="vq-auth__aside-title">{{ heading }}</p>
    {% endif %}
    {% if text != blank %}
      <p class="vq-auth__aside-text">{{ text }}</p>
    {% endif %}
  </div>
</aside>
