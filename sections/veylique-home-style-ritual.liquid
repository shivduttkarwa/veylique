{% liquid
  assign first_block = section.blocks.first
  assign total_steps = section.blocks.size
%}

<div class="veylique-section-intro veylique-section-intro-js full-width">
  <div class="veylique-container-wide">
    <h2 class="veylique-section-title">{{ section.settings.heading }}</h2>
    <p class="veylique-section-desc">{{ section.settings.text }}</p>
  </div>
</div>

<section
  class="veylique-ritual full-width"
  style="--veylique-ritual-scroll-height: {{ section.settings.scroll_height }}svh; --mustard-ritual-dot-count: {{ total_steps }};"
  aria-label="{{ section.settings.aria_label | escape }}"
  data-veylique-ritual
>
  <div class="veylique-ritual-desktop">
    <div class="veylique-ritual-stage">
      {% for block in section.blocks %}
        {% liquid
          assign step_number = forloop.index | prepend: '0' | slice: -2, 2
          assign total_number = total_steps | prepend: '0' | slice: -2, 2
        %}
        <article class="veylique-ritual-card{% if forloop.first %} is-base{% endif %}" data-title="{{ block.settings.title_main }}{% if block.settings.title_alt != blank %} {{ block.settings.title_alt }}{% endif %}" {{ block.shopify_attributes }}>
          <div class="veylique-ritual-card-body">
            <span class="veylique-ritual-card-kicker">Step {{ step_number }} / {{ total_number }}</span>
            <div class="veylique-ritual-card-main">
              <span class="veylique-ritual-card-num" aria-hidden="true">{{ step_number }}</span>
              <h3 class="veylique-ritual-card-title">
                <span class="veylique-ritual-card-title-main">{{ block.settings.title_main }}</span>
                {% if block.settings.title_alt != blank %}
                  <span class="veylique-ritual-card-title-alt">{{ block.settings.title_alt }}</span>
                {% endif %}
              </h3>
            </div>
            <span class="veylique-ritual-card-rule" aria-hidden="true"></span>
            <p class="veylique-ritual-card-text">{{ block.settings.text }}</p>
          </div>
          <div class="veylique-ritual-card-media">
            {% render 'veylique-responsive-image',
              image: block.settings.image,
              fallback: block.settings.fallback,
              class: '',
              alt: block.settings.title_main,
              width: 1200,
              height: 1500
            %}
          </div>
        </article>
      {% endfor %}
    </div>

    <div class="veylique-ritual-progress-row">
      <div class="veylique-ritual-progress-dots" aria-hidden="true">
        {% for block in section.blocks %}
          <span class="veylique-ritual-dot{% if forloop.first %} is-current{% endif %}"><span{% if forloop.first %} style="transform: scaleX(1);"{% endif %}></span></span>
        {% endfor %}
      </div>
      <div class="veylique-ritual-dot-label" data-veylique-ritual-label>
        {{ first_block.settings.title_main }} &middot; 01 / {{ total_steps | prepend: '0' | slice: -2, 2 }}
      </div>
    </div>
  </div>

  <div class="veylique-ritual-mobile">
    <div class="veylique-ritual-swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide">
            <article class="veylique-ritual-mobile-card">
              <div class="veylique-ritual-mobile-img-wrap">
                {% render 'veylique-responsive-image',
                  image: block.settings.image,
                  fallback: block.settings.fallback,
                  class: 'veylique-ritual-mobile-img',
                  alt: block.settings.title_main,
                  width: 900,
                  height: 1200
                %}
              </div>
              <div>
                <h3 class="veylique-ritual-mobile-title">{{ block.settings.title_main }}{% if block.settings.title_alt != blank %} {{ block.settings.title_alt }}{% endif %}</h3>
                <p class="veylique-ritual-mobile-text">{{ block.settings.text }}</p>
              </div>
            </article>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-home-style-ritual.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-home-style-ritual.settings.heading.label",
      "default": "your everyday<br />style edit"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-style-ritual.settings.text.label",
      "default": "Four considered steps, one confident look. A complete approach to getting dressed, built around real bodies."
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "t:sections.veylique-home-style-ritual.settings.aria_label.label",
      "default": "Veylique style edit"
    },
    {
      "type": "range",
      "id": "scroll_height",
      "label": "t:sections.veylique-home-style-ritual.settings.scroll_height.label",
      "min": 300,
      "max": 520,
      "step": 20,
      "unit": "svh",
      "default": 420
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.veylique-home-style-ritual.blocks.step.name",
      "settings": [
        {
          "type": "text",
          "id": "title_main",
          "label": "t:sections.veylique-home-style-ritual.blocks.step.settings.title_main.label",
          "default": "Discover"
        },
        {
          "type": "text",
          "id": "title_alt",
          "label": "t:sections.veylique-home-style-ritual.blocks.step.settings.title_alt.label"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.veylique-home-style-ritual.blocks.step.settings.text.label",
          "default": "Start with intention. Browse curated edits across dresses, ethnic wear, and everyday essentials - chosen for how they actually wear, not just how they photograph."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-home-style-ritual.blocks.step.settings.image.label"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "t:sections.veylique-home-style-ritual.blocks.step.settings.fallback.label",
          "default": "method-1-discover.jpg"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-style-ritual.presets.name",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        },
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}
{% endschema %}
