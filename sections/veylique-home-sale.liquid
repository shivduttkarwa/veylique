<section class="veylique-eos full-width" aria-label="{{ section.settings.aria_label | escape }}">
  <div class="veylique-eos-marquee" aria-hidden="true">
    <div class="veylique-eos-marquee-track">
      <span class="veylique-eos-marquee-seg">{{ section.settings.marquee_text }} <i>&#10022;</i> {{ section.settings.marquee_text }} <i>&#10022;</i> {{ section.settings.marquee_text }} <i>&#10022;</i> </span>
      <span class="veylique-eos-marquee-seg">{{ section.settings.marquee_text }} <i>&#10022;</i> {{ section.settings.marquee_text }} <i>&#10022;</i> {{ section.settings.marquee_text }} <i>&#10022;</i> </span>
    </div>
  </div>

  <div class="veylique-eos-main">
    <div class="veylique-eos-content">
      <span class="veylique-eos-eyebrow">{{ section.settings.kicker }}</span>
      <h2 class="veylique-eos-title">
        <span class="veylique-eos-line">{{ section.settings.heading_line_1 }}</span>
        <span class="veylique-eos-line veylique-eos-line--outline">{{ section.settings.heading_line_2 }}</span>
      </h2>
      <p class="veylique-eos-sub">{{ section.settings.offer }}<span class="veylique-eos-chip">{{ section.settings.chip }}</span></p>
      <p class="veylique-eos-desc">{{ section.settings.text }}</p>

      <div class="veylique-eos-tiers" role="list" aria-label="{{ section.settings.tiers_label | escape }}">
        <div class="veylique-eos-tier veylique-eos-tier--1" role="listitem">
          <span class="veylique-eos-tier-pct">{{ section.settings.tier_1_percent }}</span>
          <span class="veylique-eos-tier-items">{{ section.settings.tier_1_label }}</span>
        </div>
        <div class="veylique-eos-tier veylique-eos-tier--2" role="listitem">
          <span class="veylique-eos-tier-pct">{{ section.settings.tier_2_percent }}</span>
          <span class="veylique-eos-tier-items">{{ section.settings.tier_2_label }}</span>
        </div>
        <div class="veylique-eos-tier veylique-eos-tier--3" role="listitem">
          <span class="veylique-eos-tier-tag">{{ section.settings.tier_3_tag }}</span>
          <span class="veylique-eos-tier-pct">{{ section.settings.tier_3_percent }}</span>
          <span class="veylique-eos-tier-items">{{ section.settings.tier_3_label }}</span>
        </div>
      </div>

      <div class="veylique-eos-actions">
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="veylique-btn btn-white">{{ section.settings.button_label }}</a>
        <span class="veylique-eos-note">{{ section.settings.note }}</span>
      </div>
    </div>

    <div class="veylique-eos-media">
      {% if section.settings.video != blank %}
        {{ section.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, preload: 'auto', class: 'veylique-eos-video' }}
      {% elsif section.settings.poster != blank %}
        {{
          section.settings.poster
          | image_url: width: 1600
          | image_tag:
            class: 'veylique-eos-video',
            loading: 'lazy',
            widths: '600, 900, 1200, 1600',
            sizes: '100vw',
            alt: section.settings.poster.alt | default: section.settings.aria_label
        }}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'veylique-eos-video veylique-eos-video--placeholder' }}
      {% endif %}
      <div class="veylique-eos-veil" aria-hidden="true"></div>
      <div class="veylique-eos-sticker" aria-hidden="true">
        <svg viewBox="0 0 120 120" focusable="false">
          <defs>
            <path id="veyliqueEosOrbit-{{ section.id }}" d="M60 60 m -44 0 a 44 44 0 1 1 88 0 a 44 44 0 1 1 -88 0" />
          </defs>
          <text><textPath href="#veyliqueEosOrbit-{{ section.id }}">{{ section.settings.sticker_text }}</textPath></text>
        </svg>
        <span class="veylique-eos-sticker-core">{{ section.settings.sticker_core }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-home-sale.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "t:sections.veylique-home-sale.settings.aria_label.label",
      "default": "End of Season Sale"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "t:sections.veylique-home-sale.settings.marquee_text.label",
      "default": "End of the Season Sale - Get up to 40% Off - More Items, More Savings"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-home-sale.settings.kicker.label",
      "default": "Limited Time - End of Season Sale"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "t:sections.veylique-home-sale.settings.heading_line_1.label",
      "default": "End of the"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "t:sections.veylique-home-sale.settings.heading_line_2.label",
      "default": "Season Sale!"
    },
    {
      "type": "text",
      "id": "offer",
      "label": "t:sections.veylique-home-sale.settings.offer.label",
      "default": "Get up to 40% Off"
    },
    {
      "type": "text",
      "id": "chip",
      "label": "t:sections.veylique-home-sale.settings.chip.label",
      "default": "sale items"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-sale.settings.text.label",
      "default": "The more you add, the more you save - your discount steps up automatically at checkout."
    },
    {
      "type": "text",
      "id": "tiers_label",
      "label": "t:sections.veylique-home-sale.settings.tiers_label.label",
      "default": "Sale offers"
    },
    {
      "type": "text",
      "id": "tier_1_percent",
      "label": "t:sections.veylique-home-sale.settings.tier_1_percent.label",
      "default": "20%"
    },
    {
      "type": "text",
      "id": "tier_1_label",
      "label": "t:sections.veylique-home-sale.settings.tier_1_label.label",
      "default": "1-2 items"
    },
    {
      "type": "text",
      "id": "tier_2_percent",
      "label": "t:sections.veylique-home-sale.settings.tier_2_percent.label",
      "default": "30%"
    },
    {
      "type": "text",
      "id": "tier_2_label",
      "label": "t:sections.veylique-home-sale.settings.tier_2_label.label",
      "default": "3 items"
    },
    {
      "type": "text",
      "id": "tier_3_tag",
      "label": "t:sections.veylique-home-sale.settings.tier_3_tag.label",
      "default": "Best value"
    },
    {
      "type": "text",
      "id": "tier_3_percent",
      "label": "t:sections.veylique-home-sale.settings.tier_3_percent.label",
      "default": "40%"
    },
    {
      "type": "text",
      "id": "tier_3_label",
      "label": "t:sections.veylique-home-sale.settings.tier_3_label.label",
      "default": "4+ items"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-home-sale.settings.button_label.label",
      "default": "Shop the Sale"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-home-sale.settings.button_link.label"
    },
    {
      "type": "text",
      "id": "note",
      "label": "t:sections.veylique-home-sale.settings.note.label",
      "default": "On sale items - while sizes last"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.veylique-home-sale.settings.video.label"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "t:sections.veylique-home-sale.settings.poster.label",
      "info": "t:sections.veylique-home-sale.settings.poster.info"
    },
    {
      "type": "text",
      "id": "sticker_text",
      "label": "t:sections.veylique-home-sale.settings.sticker_text.label",
      "default": "More Items * More Savings * Up to 40% Off * More Items * More Savings *"
    },
    {
      "type": "text",
      "id": "sticker_core",
      "label": "t:sections.veylique-home-sale.settings.sticker_core.label",
      "default": "-40%"
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-sale.presets.name"
    }
  ]
}
{% endschema %}
