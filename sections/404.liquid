{% comment %}
  404 — shown when a customer visits an invalid store URL.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{% endcomment %}

<section class="veylique-404 veylique-page full-width">
  <div class="veylique-container veylique-404__inner">
    <p class="veylique-404__code" aria-hidden="true">404</p>
    <h1 class="veylique-404__title">{{ '404.title' | t }}</h1>
    <p class="veylique-text veylique-404__text">{{ '404.not_found' | t }}</p>

    <form action="{{ routes.search_url }}" method="get" role="search" class="veylique-search-form veylique-404__search">
      <span class="veylique-search-form__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </span>
      <input type="search" name="q" placeholder="{{ 'search.placeholder' | t }}" autocomplete="off" aria-label="{{ 'search.title' | t }}">
      <button type="submit" class="veylique-button veylique-button--solid">{{ 'search.submit' | t }}</button>
    </form>

    <div class="veylique-404__actions">
      <a href="{{ routes.root_url }}" class="veylique-button veylique-button--outline">{{ 'general.breadcrumb.home' | t }}</a>
      <a href="{{ routes.all_products_collection_url }}" class="veylique-button veylique-button--ghost">{{ '404.back_to_shopping' | t }}</a>
    </div>
  </div>
</section>

{% stylesheet %}
  .veylique-404 { padding: clamp(6rem, 12vw, 10rem) 0; }
  .veylique-404__inner {
    max-width: 40rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .veylique-404__code {
    margin: 0;
    font-family: var(--veylique-font-heading);
    font-size: clamp(6rem, 22vw, 13rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 0.0625rem var(--veylique-color-border);
  }
  .veylique-404__title {
    margin: 0.5rem 0 0.75rem;
    font-family: var(--veylique-font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--veylique-color-foreground);
  }
  .veylique-404__text { max-width: 30rem; margin-bottom: 2rem; }
  .veylique-404__search { width: min(100%, 30rem); margin-bottom: 1.5rem; }
  .veylique-404__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }

  /* Search field (shared look with the search page). */
  .veylique-search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--veylique-color-surface, #fff);
    border: var(--veylique-border-width) solid var(--veylique-color-border);
    border-radius: var(--veylique-radius-pill);
    padding: 0.375rem 0.375rem 0.375rem 1rem;
  }
  .veylique-search-form__icon { display: inline-flex; color: var(--veylique-color-muted); }
  .veylique-search-form input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    padding: 0.75rem 0.25rem;
    font: inherit;
    color: var(--veylique-color-foreground);
  }
  .veylique-search-form input:focus { outline: none; }
  .veylique-search-form .veylique-button { flex: 0 0 auto; white-space: nowrap; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.404",
  "settings": []
}
{% endschema %}
