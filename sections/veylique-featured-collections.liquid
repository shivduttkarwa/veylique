<section class="veylique-page veylique-section" aria-labelledby="VeyliqueCollectionsTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueCollectionsTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        {% liquid
          assign card_title = block.settings.heading
          assign card_link = block.settings.link
          assign card_image = block.settings.image
          if block.settings.collection != blank
            assign card_title = card_title | default: block.settings.collection.title
            assign card_link = card_link | default: block.settings.collection.url
            assign card_image = card_image | default: block.settings.collection.featured_image
          endif
        %}
        <a class="veylique-image-card" href="{{ card_link | default: routes.collections_url }}" {{ block.shopify_attributes }}>
          <span class="veylique-image-card__media">
            {% render 'veylique-responsive-image',
              image: card_image,
              fallback: block.settings.fallback,
              class: 'veylique-media',
              alt: card_title,
              width: 900
            %}
          </span>
          <span class="veylique-card-body">
            <span class="veylique-card-title">{{ card_title | escape }}</span>
            <span class="veylique-card-sub">{{ section.settings.link_label | escape }}</span>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-featured-collections.name",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-featured-collections.settings.kicker.label",
      "default": "Shop by category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-featured-collections.settings.heading.label",
      "default": "Shop by category"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-featured-collections.settings.text.label",
      "default": "Explore the collection organised by mood, occasion, and everyday need."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "t:sections.veylique-featured-collections.settings.link_label.label",
      "default": "View"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.veylique-featured-collections.settings.columns_desktop.label",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.veylique-featured-collections.blocks.collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.veylique-featured-collections.blocks.collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-featured-collections.blocks.collection.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.veylique-featured-collections.blocks.collection.settings.heading.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.veylique-featured-collections.blocks.collection.settings.link.label"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "t:sections.veylique-featured-collections.blocks.collection.settings.fallback.label",
          "default": "hero-2.webp"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-featured-collections.presets.name",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "heading": "Dresses",
            "fallback": "hero-2.webp"
          }
        },
        {
          "type": "collection",
          "settings": {
            "heading": "Ethnic wear",
            "fallback": "hero-3.webp"
          }
        },
        {
          "type": "collection",
          "settings": {
            "heading": "Western wear",
            "fallback": "hero-4.webp"
          }
        },
        {
          "type": "collection",
          "settings": {
            "heading": "Accessories",
            "fallback": "hero-5.webp"
          }
        }
      ]
    }
  ]
}
{% endschema %}
