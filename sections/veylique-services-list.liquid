<section class="veylique-page veylique-section" aria-labelledby="VeyliqueServicesTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueServicesTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        <article class="veylique-article-card" {{ block.shopify_attributes }}>
          <span class="veylique-article-card__media">
            {% render 'veylique-responsive-image',
              image: block.settings.image,
              fallback: block.settings.fallback,
              class: 'veylique-media',
              alt: block.settings.heading,
              width: 900
            %}
          </span>
          <span class="veylique-card-body">
            <span>
              <span class="veylique-card-title">{{ block.settings.heading | escape }}</span>
              <span class="veylique-card-sub">{{ block.settings.text | escape }}</span>
            </span>
          </span>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-services-list.name",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-services-list.settings.kicker.label",
      "default": "What we offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-services-list.settings.heading.label",
      "default": "Our services"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-services-list.settings.text.label",
      "default": "Personal styling, fit guidance, wardrobe edits, and occasion dressing."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.veylique-services-list.settings.columns_desktop.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "t:sections.veylique-services-list.blocks.service.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-services-list.blocks.service.settings.image.label"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "t:sections.veylique-services-list.blocks.service.settings.fallback.label",
          "default": "service-1-consult-1.jpg"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.veylique-services-list.blocks.service.settings.heading.label",
          "default": "Personal styling"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.veylique-services-list.blocks.service.settings.text.label",
          "default": "A guided session to refine silhouettes, palette, and outfit formulas."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-services-list.presets.name",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "heading": "Personal styling",
            "fallback": "service-1-consult-1.jpg"
          }
        },
        {
          "type": "service",
          "settings": {
            "heading": "Wardrobe edit",
            "fallback": "service-2-consult-1.jpg"
          }
        },
        {
          "type": "service",
          "settings": {
            "heading": "Occasion dressing",
            "fallback": "service-3-consult-1.jpg"
          }
        }
      ]
    }
  ]
}
{% endschema %}
