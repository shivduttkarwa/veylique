{% javascript %}
  (function () {
    function initCollection(root) {
      var sections = root.querySelectorAll('[data-veylique-collection]');
      sections.forEach(function (section) {
        if (section.dataset.veyliqueCollectionReady === 'true') return;
        section.dataset.veyliqueCollectionReady = 'true';

        var facets = section.querySelector('[data-veylique-facets]');
        var overlay = section.querySelector('.veylique-facets__overlay');
        var openBtn = section.querySelector('[data-veylique-drawer-open]');

        function openDrawer() {
          if (!facets) return;
          facets.classList.add('is-open');
          if (overlay) {
            overlay.hidden = false;
            requestAnimationFrame(function () { overlay.classList.add('is-open'); });
          }
          if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        }

        function closeDrawer() {
          if (!facets) return;
          facets.classList.remove('is-open');
          if (overlay) {
            overlay.classList.remove('is-open');
            var hide = function () { overlay.hidden = true; overlay.removeEventListener('transitionend', hide); };
            overlay.addEventListener('transitionend', hide);
          }
          if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }

        if (openBtn) openBtn.addEventListener('click', openDrawer);
        section.querySelectorAll('[data-veylique-drawer-close]').forEach(function (el) {
          el.addEventListener('click', closeDrawer);
        });
        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && facets && facets.classList.contains('is-open')) closeDrawer();
        });

        /* Auto-submit sort on change */
        var sortSelect = section.querySelector('[data-veylique-sort]');
        if (sortSelect) {
          sortSelect.addEventListener('change', function () {
            var form = sortSelect.closest('form');
            if (form) form.submit();
          });
        }

        /* Auto-submit facets on desktop; on mobile wait for Apply */
        var facetForm = section.querySelector('[data-veylique-facet-form]');
        if (facetForm) {
          facetForm.addEventListener('change', function (event) {
            if (event.target.type === 'checkbox' && window.matchMedia('(min-width: 990px)').matches) {
              facetForm.submit();
            }
          });
        }

        /* Column switcher (desktop) */
        var grid = section.querySelector('[data-veylique-grid]');
        var colBtns = section.querySelectorAll('[data-veylique-cols]');
        var storeKey = 'veylique:cols:' + (section.id || 'collection');
        function applyCols(value, btn) {
          if (grid) grid.style.setProperty('--cols-d', value);
          colBtns.forEach(function (b) { b.classList.toggle('is-active', b === btn); });
        }
        var saved = null;
        try { saved = window.localStorage.getItem(storeKey); } catch (e) {}
        colBtns.forEach(function (btn) {
          if (saved && btn.dataset.veyliqueCols === saved) applyCols(saved, btn);
          btn.addEventListener('click', function () {
            var value = btn.dataset.veyliqueCols;
            applyCols(value, btn);
            try { window.localStorage.setItem(storeKey, value); } catch (e) {}
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { initCollection(document); });
    } else {
      initCollection(document);
    }
    document.addEventListener('shopify:section:load', function (event) { initCollection(event.target); });
  })();
{% endjavascript %}

