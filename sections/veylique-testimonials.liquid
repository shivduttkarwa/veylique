<section class="veylique-page veylique-section" aria-labelledby="VeyliqueTestimonialsTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueTestimonialsTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        <figure class="veylique-quote-card" {{ block.shopify_attributes }}>
          <blockquote class="veylique-text">{{ block.settings.quote }}</blockquote>
          <figcaption class="veylique-card-title">
            {{ block.settings.name | escape }}
            {% if block.settings.location != blank %}
              <span class="veylique-card-sub">{{ block.settings.location | escape }}</span>
            {% endif %}
          </figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Customer stories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved for fit, ease, and detail" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Add social proof that feels specific and useful." },
    { "type": "range", "id": "columns_desktop", "label": "Columns on desktop", "min": 2, "max": 4, "step": 1, "default": 3 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "inline_richtext", "id": "quote", "label": "Quote", "default": "Veylique makes getting dressed feel effortless. Every piece feels considered." },
        { "type": "text", "id": "name", "label": "Name", "default": "Ananya R." },
        { "type": "text", "id": "location", "label": "Location", "default": "Mumbai" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial", "settings": { "name": "Priya M.", "location": "Bengaluru", "quote": "The fabrics are soft, the cuts are easy, and the styling feels grown-up without feeling stiff." } },
        { "type": "testimonial", "settings": { "name": "Kavya S.", "location": "Delhi", "quote": "I bought one dress for travel and now reach for it every week." } }
      ]
    }
  ]
}
{% endschema %}
