{% comment %}
  Customer registration — classic customer accounts. Editorial split layout
  matching the login page.
{% endcomment %}

<section class="vq-auth" aria-labelledby="RegisterTitle-{{ section.id }}">
  {% render 'veylique-auth-aside',
    image: section.settings.image,
    fallback: section.settings.fallback,
    eyebrow: section.settings.aside_eyebrow,
    heading: section.settings.aside_heading,
    text: section.settings.aside_text
  %}

  <div class="vq-auth__panel">
    <div class="vq-auth__card">
      <div class="vq-auth__head">
        <span class="vq-auth__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        <h1 id="RegisterTitle-{{ section.id }}" class="vq-auth__title">{{ section.settings.heading | escape }}</h1>
        {% if section.settings.subheading != blank %}
          <p class="vq-auth__subtitle">{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>

      {% form 'create_customer', class: 'vq-form' %}
        {% if form.errors %}
          <div class="vq-alert vq-alert--error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="vq-field__row">
          <div class="vq-field">
            <label class="vq-label" for="RegisterFirstName-{{ section.id }}">{{ 'customers.register.first_name' | t }}</label>
            <input
              type="text"
              class="vq-input"
              id="RegisterFirstName-{{ section.id }}"
              name="customer[first_name]"
              value="{{ form.first_name }}"
              autocomplete="given-name"
              autocapitalize="words"
            >
          </div>
          <div class="vq-field">
            <label class="vq-label" for="RegisterLastName-{{ section.id }}">{{ 'customers.register.last_name' | t }}</label>
            <input
              type="text"
              class="vq-input"
              id="RegisterLastName-{{ section.id }}"
              name="customer[last_name]"
              value="{{ form.last_name }}"
              autocomplete="family-name"
              autocapitalize="words"
            >
          </div>
        </div>

        <div class="vq-field">
          <label class="vq-label" for="RegisterEmail-{{ section.id }}">{{ 'customers.login.email' | t }}</label>
          <input
            type="email"
            class="vq-input"
            id="RegisterEmail-{{ section.id }}"
            name="customer[email]"
            value="{{ form.email }}"
            autocomplete="email"
            autocapitalize="off"
            spellcheck="false"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            required
          >
        </div>

        <div class="vq-field">
          <label class="vq-label" for="RegisterPassword-{{ section.id }}">{{ 'customers.login.password' | t }}</label>
          <input
            type="password"
            class="vq-input"
            id="RegisterPassword-{{ section.id }}"
            name="customer[password]"
            autocomplete="new-password"
            placeholder="{{ section.settings.password_placeholder | escape }}"
            required
          >
        </div>

        <button type="submit" class="veylique-btn btn-black veylique-btn--block">{{ 'customers.register.submit' | t }}</button>
      {% endform %}

      <p class="vq-auth__foot">
        {{ 'customers.register.have_account' | t }}
        <a href="{{ routes.account_login_url }}">{{ 'customers.register.sign_in' | t }}</a>
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "settings": [
    { "type": "header", "content": "t:sections.main-register.settings.form_header.content" },
    { "type": "text", "id": "eyebrow", "label": "t:sections.main-login.settings.eyebrow.label", "default": "Account" },
    { "type": "text", "id": "heading", "label": "t:sections.main-register.settings.heading.label", "default": "Create your account" },
    { "type": "text", "id": "subheading", "label": "t:sections.main-register.settings.subheading.label", "default": "Save your details, track orders and check out faster next time." },
    { "type": "text", "id": "email_placeholder", "label": "t:sections.main-login.settings.email_placeholder.label", "default": "you@example.com" },
    { "type": "text", "id": "password_placeholder", "label": "t:sections.main-login.settings.password_placeholder.label", "default": "At least 5 characters" },
    { "type": "header", "content": "t:sections.main-login.settings.aside_header.content" },
    { "type": "image_picker", "id": "image", "label": "t:sections.main-login.settings.image.label" },
    { "type": "text", "id": "fallback", "label": "t:sections.main-login.settings.fallback.label", "default": "hero-4.webp" },
    { "type": "text", "id": "aside_eyebrow", "label": "t:sections.main-login.settings.aside_eyebrow.label", "default": "Veylique" },
    { "type": "text", "id": "aside_heading", "label": "t:sections.main-login.settings.aside_heading.label", "default": "Join the Veylique circle." },
    { "type": "text", "id": "aside_text", "label": "t:sections.main-login.settings.aside_text.label", "default": "Early access to new arrivals, saved sizes and a faster checkout — all in one place." }
  ]
}
{% endschema %}
