<div class="veylique-section-intro veylique-section-intro-js veylique-latest-intro full-width">
  <div class="veylique-container-wide">
    <h2 class="veylique-section-title">{{ section.settings.heading }}</h2>
    <p class="veylique-section-desc">{{ section.settings.text }}</p>
  </div>
</div>

<section class="veylique-latest full-width" aria-label="{{ section.settings.heading | escape }}">
  <div class="veylique-latest-grid">
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>
        {% render 'veylique-home-product-card',
          variant: 'latest',
          product: block.settings.product,
          title: block.settings.title,
          category: block.settings.category,
          badge: block.settings.badge,
          price: block.settings.price,
          compare_price: block.settings.compare_price,
          image: block.settings.image,
          hover_image: block.settings.hover_image,
          fallback: block.settings.fallback,
          hover_fallback: block.settings.hover_fallback,
          link: block.settings.link
        %}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.button_label != blank %}
    <div class="veylique-latest-cta">
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="veylique-btn btn-black">{{ section.settings.button_label }}</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Veylique latest products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Latest Products" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Freshly launched styles and seasonal essentials selected for your next outfit." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View All Products" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "image_picker", "id": "hover_image", "label": "Hover image" },
        { "type": "text", "id": "fallback", "label": "Fallback asset filename", "default": "hero-1.webp" },
        { "type": "text", "id": "hover_fallback", "label": "Hover fallback asset filename", "default": "hero-2.webp" },
        { "type": "text", "id": "category", "label": "Category", "default": "Dresses" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "New" },
        { "type": "text", "id": "title", "label": "Fallback title", "default": "Linen Wrap Dress" },
        { "type": "text", "id": "price", "label": "Fallback price", "default": "$72.00" },
        { "type": "text", "id": "compare_price", "label": "Fallback compare price" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Veylique latest products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
