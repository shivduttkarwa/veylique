{% liquid
  assign values_bg = ''
  if section.settings.image != blank
    assign values_bg = section.settings.image | image_url: width: 2400
  elsif section.settings.fallback != blank
    assign values_bg = section.settings.fallback | asset_url
  endif
%}

<section
  class="veylique-about-values full-width"
  {% if values_bg != blank %}style="--mustard-about-bg: url('{{ values_bg }}')"{% endif %}
  data-veylique-about-values
>
  <div class="veylique-about-values-wrap">
    <div class="veylique-section-intro veylique-section-intro-js veylique-section-intro--flush">
      <div class="veylique-container-wide container-fluid">
        <div class="row">
          <div class="col-12 col-xl-10">
            {%- if section.settings.eyebrow != blank -%}
              <span class="veylique-eyebrow">{{ section.settings.eyebrow | escape }}</span>
            {%- endif -%}
            <h2 class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
          </div>
        </div>
      </div>
    </div>

    <div class="veylique-about-values-grid" data-veylique-about-values-grid>
      {%- for block in section.blocks -%}
        <div class="veylique-about-val veylique-about-val-reveal-js" {{ block.shopify_attributes }}>
          {%- if block.settings.watermark != blank -%}
            <div class="veylique-about-val-wm">{{ block.settings.watermark | escape }}</div>
          {%- endif -%}
          <span class="veylique-about-val-idx">{{ block.settings.index | escape }}</span>
          <h3 class="veylique-about-val-h3">{{ block.settings.heading | escape }}</h3>
          <p class="veylique-about-val-p">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .veylique-about-values {
    position: relative;
    background-color: #0e0b0a;
    background-image: var(--mustard-about-bg, var(--mustard-placeholder-bg));
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: clamp(5rem, 10vw, 8.125rem) 0;
  }
  .veylique-about-values::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(14, 11, 10, 0.86);
    pointer-events: none;
  }
  .veylique-about-values-wrap {
    position: relative;
    z-index: 1;
    max-width: calc(75rem + 2 * var(--mustard-container-gutter));
    margin-inline: auto;
    padding-inline: var(--mustard-container-gutter);
  }
  .veylique-about-values .veylique-section-intro {
    position: relative;
    z-index: 1;
    padding: 0 0 2rem;
  }
  .veylique-about-values .veylique-eyebrow { color: rgba(255, 255, 255, 0.6); }
  .veylique-about-values .veylique-section-title { color: #fff; }
  .veylique-about-values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.125rem; }
  .veylique-about-val {
    position: relative;
    overflow: hidden;
    padding: 2.5rem 2.25rem;
    border: 0.0625rem solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.02);
    transition: background 0.25s;
  }
  .veylique-about-val:hover { background: rgba(255, 255, 255, 0.045); }
  .veylique-about-val-wm {
    position: absolute;
    bottom: -1rem;
    right: -0.25rem;
    font-family: "Clash Display", Inter, sans-serif;
    font-size: clamp(6.875rem, 16vw, 12.5rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 1;
    color: rgba(255, 255, 255, 0.035);
    user-select: none;
    pointer-events: none;
  }
  .veylique-about-val-idx {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mustard-accent);
    margin-bottom: 1.25rem;
  }
  .veylique-about-val-h3 {
    margin: 0 0 0.75rem;
    font-family: "Clash Display", Inter, sans-serif;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: #fff;
  }
  .veylique-about-val-p { margin: 0; font-size: 0.875rem; line-height: 1.8; color: rgba(255, 255, 255, 0.42); }

  @media (max-width: 1024px) {
    .veylique-about-values-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .veylique-about-values-grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function whenReady(cb) {
      var n = 0;
      (function check() {
        if (window.gsap && window.ScrollTrigger) { cb(); return; }
        if (n++ > 200) return;
        requestAnimationFrame(check);
      })();
    }
    function initVals(root) {
      var sections = root.querySelectorAll('[data-veylique-about-values]');
      sections.forEach(function (section) {
        if (section.dataset.veyliqueValsReady === 'true') return;
        section.dataset.veyliqueValsReady = 'true';
        window.gsap.registerPlugin(window.ScrollTrigger);

        var grid = section.querySelector('[data-veylique-about-values-grid]');
        var cards = Array.prototype.slice.call(section.querySelectorAll('.veylique-about-val-reveal-js'));
        if (!grid || !cards.length) return;

        window.gsap.set(cards, { autoAlpha: 0, y: 32 });
        window.ScrollTrigger.create({
          trigger: grid,
          start: 'top 75%',
          once: true,
          onEnter: function () {
            window.gsap.to(cards, { autoAlpha: 1, y: 0, duration: 0.75, ease: 'power3.out', stagger: 0.15 });
          }
        });
      });
    }

    function boot(root) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      whenReady(function () { initVals(root); });
    }
    if (document.readyState === 'complete') {
      boot(document);
    } else {
      document.addEventListener('DOMContentLoaded', function () { boot(document); });
    }
    document.addEventListener('shopify:section:load', function (event) { boot(event.target); });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.veylique-about-values.name",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.veylique-about-values.settings.eyebrow.label",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-about-values.settings.heading.label",
      "default": "Three principles. Every decision."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.veylique-about-values.settings.image.label"
    },
    {
      "type": "text",
      "id": "fallback",
      "label": "t:sections.veylique-about-values.settings.fallback.label",
      "default": "hero-4.webp"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "t:sections.veylique-about-values.blocks.value.name",
      "settings": [
        {
          "type": "text",
          "id": "watermark",
          "label": "t:sections.veylique-about-values.blocks.value.settings.watermark.label",
          "default": "I"
        },
        {
          "type": "text",
          "id": "index",
          "label": "t:sections.veylique-about-values.blocks.value.settings.index.label",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.veylique-about-values.blocks.value.settings.heading.label",
          "default": "Material Honesty"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.veylique-about-values.blocks.value.settings.text.label",
          "default": "We choose breathable weaves, soft linings, and finishes that feel good against the body and stand up to everyday wear."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-about-values.presets.name",
      "blocks": [
        { "type": "value", "settings": { "watermark": "I", "index": "01", "heading": "Material Honesty", "text": "We choose breathable weaves, soft linings, and finishes that feel good against the body and stand up to everyday wear." } },
        { "type": "value", "settings": { "watermark": "II", "index": "02", "heading": "Fit Precision", "text": "A beautiful print is only half the work. We tune proportions, seams, and closures until every piece feels natural to move in." } },
        { "type": "value", "settings": { "watermark": "III", "index": "03", "heading": "Mindful Fashion", "text": "Premium should feel considered. We design versatile pieces that can be styled often, cared for easily, and loved longer." } }
      ]
    }
  ]
}
{% endschema %}
