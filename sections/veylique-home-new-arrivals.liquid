{% liquid
  assign product_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign has_products = false
  if product_collection != blank and product_collection.products.size > 0
    assign has_products = true
  endif

  if has_products
    assign first_product = product_collection.products.first
    assign first_text = first_product.title
    assign first_link = first_product.url
  else
    assign first_text = section.settings.text
    assign first_link = routes.all_products_collection_url
  endif
%}

<div class="veylique-arrivals-band full-width" data-veylique-arrivals>
  <div class="veylique-section-intro veylique-section-intro-js">
    <div class="veylique-container-wide">
      <div class="row">
        <div class="col-12 col-xl-10">
          <h2 class="veylique-section-title">{{ section.settings.heading }}</h2>
          <p class="veylique-section-desc">{{ section.settings.text }}</p>
        </div>
      </div>
    </div>
  </div>

  <section class="veylique-slider-section container-fluid px-0" aria-label="{{ section.settings.aria_label | escape }}">
    <div class="veylique-slider-stage is-loading" id="veyliqueSlider-{{ section.id }}">
      <div class="veylique-slides" id="veyliqueSlides-{{ section.id }}">
        {% if has_products %}
          {% for product in product_collection.products limit: products_to_show %}
            {% liquid
              assign slide_number = forloop.index | prepend: '0' | slice: -2, 2
              assign slide_loading = 'lazy'
              if forloop.first
                assign slide_loading = 'eager'
              endif
            %}
            <div
              class="veylique-slide{% if forloop.first %} is-active{% elsif forloop.index == 2 %} is-next{% else %} is-hidden-right{% endif %}"
              data-veylique-arrivals-slide
              data-index="{{ forloop.index0 }}"
              data-number="{{ slide_number }}"
              data-text="{{ product.title | escape }}"
              data-url="{{ product.url }}"
            >
              <div class="veylique-slide-inner">
                {% render 'veylique-responsive-image',
                  image: product.featured_image,
                  class: '',
                  alt: product.title,
                  width: 1200,
                  height: 1500,
                  loading: slide_loading,
                  placeholder: true
                %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..products_to_show) %}
            {% liquid
              assign slide_number = forloop.index | prepend: '0' | slice: -2, 2
              assign slide_loading = 'lazy'
              if forloop.first
                assign slide_loading = 'eager'
              endif
            %}
            <div
              class="veylique-slide{% if forloop.first %} is-active{% elsif forloop.index == 2 %} is-next{% else %} is-hidden-right{% endif %}"
              data-veylique-arrivals-slide
              data-index="{{ forloop.index0 }}"
              data-number="{{ slide_number }}"
              data-text="{{ section.settings.text | escape }}"
              data-url="{{ routes.all_products_collection_url }}"
            >
              <div class="veylique-slide-inner">
                {% render 'veylique-responsive-image',
                  class: '',
                  alt: section.settings.heading,
                  width: 1200,
                  height: 1500,
                  loading: slide_loading,
                  placeholder: true,
                  placeholder_name: 'product-apparel-1'
                %}
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <div class="veylique-hit-area" aria-hidden="true">
        <button type="button" data-direction="prev" data-veylique-arrivals-dir="prev" aria-label="{{ section.settings.previous_label | escape }}"></button>
        <button type="button" data-direction="next" data-veylique-arrivals-dir="next" aria-label="{{ section.settings.next_label | escape }}"></button>
      </div>

      <article class="veylique-content-card" id="veyliqueCard-{{ section.id }}">
        <div class="veylique-card-body">
          <span class="veylique-slide-number veylique-reveal-js veylique-reveal--static-js" id="veyliqueNumber-{{ section.id }}" data-veylique-arrivals-number>01</span>
          <p class="veylique-card-text veylique-reveal-js veylique-reveal--static-js" id="veyliqueText-{{ section.id }}" data-veylique-arrivals-text>{{ first_text }}</p>
        </div>
        <a href="{{ first_link }}" id="veyliqueCardButton-{{ section.id }}" class="veylique-card-button veylique-reveal-js veylique-reveal--static-js" data-veylique-arrivals-link>{{ section.settings.button_label }}</a>
      </article>

      <div class="veylique-mobile-arrows" aria-label="{{ section.settings.controls_label | escape }}">
        <button type="button" class="veylique-mobile-arrow veylique-mobile-arrow--prev" data-direction="prev" data-veylique-arrivals-dir="prev" aria-label="{{ section.settings.previous_label | escape }}"></button>
        <button type="button" class="veylique-mobile-arrow veylique-mobile-arrow--next" data-direction="next" data-veylique-arrivals-dir="next" aria-label="{{ section.settings.next_label | escape }}"></button>
      </div>

      <div class="veylique-cursor-arrow" id="veyliqueCursorArrow-{{ section.id }}" aria-hidden="true"></div>
    </div>
  </section>
</div>

{% stylesheet %}
.veylique-slider-section {
  --mustard-black: #111111;
  --mustard-white: #ffffff;
  --mustard-glass: rgba(255, 255, 255, 0.34);
  --mustard-border: rgba(17, 17, 17, 0.92);
  --mustard-ease: cubic-bezier(0.19, 1, 0.22, 1);
  --mustard-duration: 1280ms;
  position: relative;
  width: 100%;
  height: 70vh;
  min-height: 34rem;
  overflow: hidden;
  background: #ffffff;
}

.veylique-arrivals-band {
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

@media (min-width: 992px) {
  .veylique-arrivals-band {
    height: min(92vh, 58rem);
    min-height: 42rem;
  }

  .veylique-arrivals-band .veylique-section-intro {
    flex: 0 0 auto;
  }

  .veylique-arrivals-band .veylique-slider-section {
    flex: 1 1 auto;
    height: auto;
    min-height: 0;
  }

  .veylique-arrivals-band .veylique-slide img,
  .veylique-arrivals-band .veylique-slide .veylique-media-placeholder {
    height: 117%;
    max-height: none;
  }

  .veylique-arrivals-band .veylique-content-card {
    top: auto;
    bottom: 1.75rem;
  }
}

.veylique-slider-stage {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  cursor: none;
  user-select: none;
  contain: layout paint;
  background: #ffffff;
  touch-action: pan-y;
}

.veylique-slides {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.veylique-slide {
  position: absolute;
  top: 0;
  left: 50%;
  width: 34vw;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transform: translate3d(calc(-50% + var(--x, 0vw)), 0, 0) scale(var(--slide-scale, 1));
  transition:
    transform var(--mustard-duration) var(--mustard-ease),
    opacity 850ms var(--mustard-ease),
    filter 850ms var(--mustard-ease);
  will-change: transform, opacity;
  backface-visibility: hidden;
  transform-style: preserve-3d;
}

.veylique-slide.is-active,
.veylique-slide.is-prev,
.veylique-slide.is-next {
  opacity: 1;
}

.veylique-slide.is-active {
  --x: 0vw;
  --slide-scale: 0.9;
  z-index: 5;
  filter: saturate(1);
}

.veylique-slide.is-prev {
  --x: -58vw;
  --slide-scale: 0.985;
  z-index: 2;
  filter: saturate(0.9);
}

.veylique-slide.is-next {
  --x: 58vw;
  --slide-scale: 0.985;
  z-index: 2;
  filter: saturate(0.9);
}

.veylique-slide.is-hidden-left {
  --x: -112vw;
  --slide-scale: 0.96;
  z-index: 1;
  opacity: 0;
}

.veylique-slide.is-hidden-right {
  --x: 112vw;
  --slide-scale: 0.96;
  z-index: 1;
  opacity: 0;
}

.veylique-slide-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate3d(0, 0, 0) scale(var(--image-scale, 1.08));
  transform-origin: center center;
  transition: transform var(--mustard-duration) var(--mustard-ease);
  will-change: transform;
  backface-visibility: hidden;
}

.veylique-slide.is-active .veylique-slide-inner {
  --image-scale: 1;
}

.veylique-slide.is-prev .veylique-slide-inner,
.veylique-slide.is-next .veylique-slide-inner {
  --image-scale: 1.08;
}

.veylique-slide.is-hidden-left .veylique-slide-inner,
.veylique-slide.is-hidden-right .veylique-slide-inner {
  --image-scale: 1.16;
}

.veylique-slide img,
.veylique-slide .veylique-media-placeholder {
  width: 100%;
  max-width: 42.5rem;
  height: 82vh;
  max-height: 49.375rem;
  object-fit: cover;
  display: block;
  pointer-events: none;
  user-select: none;
  transform: translate3d(0, 0, 0);
  backface-visibility: hidden;
}

.veylique-hit-area {
  position: absolute;
  inset: 0;
  z-index: 16;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.veylique-hit-area button {
  appearance: none;
  border: 0;
  padding: 0;
  background: transparent;
  cursor: none;
}

.veylique-content-card {
  position: absolute;
  top: 38%;
  left: 64%;
  z-index: 22;
  width: min(21.25rem, 58vw);
  min-height: 22rem;
  display: flex;
  flex-direction: column;
  transform: translate3d(-8%, 0, 0);
  border: 0.0625rem solid rgba(17, 17, 17, 0.92);
  background: var(--mustard-glass);
  backdrop-filter: blur(1.125rem);
  -webkit-backdrop-filter: blur(1.125rem);
  box-shadow: 0 1.125rem 3.5rem rgba(0, 0, 0, 0.08);
  pointer-events: none;
  transition: opacity 520ms ease, transform 520ms var(--mustard-ease);
  will-change: opacity, transform;
}

.veylique-content-card.is-changing {
  opacity: 0;
  transform: translate3d(-8%, 1.125rem, 0);
}

.veylique-slider-section .veylique-card-body {
  flex: 1 1 auto;
  display: block;
  padding: 2.25rem 1.5rem 1.5rem;
}

.veylique-slide-number {
  display: block;
  margin: 0 0 2.125rem;
  font-family: var(--mustard-font-heading);
  font-size: clamp(5.375rem, 7.2vw, 8.25rem);
  font-weight: 400;
  line-height: 0.72;
  letter-spacing: -0.09em;
}

.veylique-card-text {
  max-width: 15.625rem;
  margin: 0;
  font-family: var(--mustard-font-body);
  font-size: 1rem;
  font-weight: 400;
  line-height: 1.45;
  letter-spacing: -0.03em;
}

.veylique-card-button {
  flex: 0 0 auto;
  display: block;
  width: 100%;
  padding: 0.875rem 1.125rem;
  pointer-events: auto;
  border-top: 0.0625rem solid rgba(17, 17, 17, 0.92);
  color: var(--mustard-black);
  font-family: var(--mustard-font-body);
  font-size: 1rem;
  font-weight: 500;
  text-align: center;
  text-decoration: none;
  transition: background 250ms ease, color 250ms ease;
}

.veylique-card-button:hover {
  background: var(--mustard-black);
  color: var(--mustard-white);
}

.veylique-slider-stage.is-cursor-default,
.veylique-slider-stage.is-cursor-default .veylique-hit-area button {
  cursor: default;
}

.veylique-cursor-arrow {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 90;
  width: 8.125rem;
  height: 1.75rem;
  pointer-events: none;
  opacity: 0;
  transform: translate3d(-50%, -50%, 0) scale(0.7);
  transition: opacity 180ms ease, transform 180ms ease;
  will-change: transform, opacity;
}

.veylique-cursor-arrow.is-visible {
  opacity: 1;
}

.veylique-cursor-arrow.is-left {
  transform: translate3d(-50%, -50%, 0) scale(1) rotate(180deg);
}

.veylique-cursor-arrow.is-right {
  transform: translate3d(-50%, -50%, 0) scale(1) rotate(0deg);
}

.veylique-cursor-arrow::before,
.veylique-mobile-arrow::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 0.0625rem;
  background: var(--mustard-black, #111111);
  transform: translateY(-50%);
}

.veylique-cursor-arrow::after,
.veylique-mobile-arrow::after {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  width: 0.8125rem;
  height: 0.8125rem;
  border-top: 0.0625rem solid var(--mustard-black, #111111);
  border-right: 0.0625rem solid var(--mustard-black, #111111);
  transform: translateY(-50%) rotate(45deg);
}

.veylique-mobile-arrows {
  position: absolute;
  left: 50%;
  bottom: 2.125rem;
  z-index: 35;
  width: min(26.25rem, 84vw);
  display: none;
  justify-content: space-between;
  transform: translateX(-50%);
  pointer-events: auto;
}

.veylique-mobile-arrow {
  position: relative;
  width: 5.75rem;
  height: 2.125rem;
  border: 0;
  background: transparent;
  cursor: pointer;
}

.veylique-mobile-arrow--prev {
  transform: rotate(180deg);
}

.veylique-mobile-arrow.is-disabled {
  cursor: default;
  opacity: 0.2;
  pointer-events: none;
}

.veylique-mobile-arrow::after {
  width: 0.6875rem;
  height: 0.6875rem;
}

.veylique-slider-stage.is-loading .veylique-slide,
.veylique-slider-stage.is-loading .veylique-slide-inner {
  animation: none;
  transition: none;
}

@media (max-width: 1200px) {
  .veylique-slider-stage {
    cursor: auto;
  }

  .veylique-hit-area,
  .veylique-cursor-arrow {
    display: none;
  }

  .veylique-mobile-arrows {
    display: flex;
  }

  .veylique-slide {
    width: 50vw;
  }

  .veylique-slide.is-prev {
    --x: -68vw;
  }

  .veylique-slide.is-next {
    --x: 68vw;
  }
}

@media (max-width: 768px) {
  .veylique-slider-section {
    height: 60vh;
    min-height: 30rem;
  }

  .veylique-slide {
    width: 78vw;
    align-items: flex-start;
    padding-top: 1rem;
  }

  .veylique-slide-inner {
    align-items: flex-start;
  }

  .veylique-slide img,
  .veylique-slide .veylique-media-placeholder {
    height: 45vh;
    max-height: 28.75rem;
  }

  .veylique-slide.is-prev {
    --x: -102vw;
  }

  .veylique-slide.is-next {
    --x: 102vw;
  }

  .veylique-content-card {
    top: calc(1rem + min(45vh, 28.75rem) - 1.75rem);
    left: 50%;
    width: min(18.75rem, calc(100vw - 2.75rem));
    min-height: 0;
    transform: translate3d(calc(-50% + 6rem), 0, 0);
  }

  .veylique-content-card.is-changing {
    transform: translate3d(calc(-50% + 6rem), 1.125rem, 0);
  }

  .veylique-slider-section .veylique-card-body {
    padding: 1.25rem 1.125rem 1rem;
  }

  .veylique-slide-number {
    margin-bottom: 1.75rem;
    font-size: 5.25rem;
  }

  .veylique-card-text,
  .veylique-card-button {
    font-size: 0.8125rem;
  }

  .veylique-mobile-arrows {
    bottom: 1rem;
  }
}

@media (max-width: 480px) {
  .veylique-slider-section {
    min-height: 28rem;
  }

  .veylique-slide {
    width: 86vw;
  }

  .veylique-content-card {
    width: min(17.375rem, calc(100vw - 2.25rem));
    transform: translate3d(calc(-50% + 2.5rem), 0, 0);
  }

  .veylique-content-card.is-changing {
    transform: translate3d(calc(-50% + 2.5rem), 1.125rem, 0);
  }

  .veylique-slide-number {
    font-size: 4.5rem;
  }

  .veylique-slider-section .veylique-card-body {
    padding: 1.375rem 1.125rem 1.125rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.veylique-home-new-arrivals.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-home-new-arrivals.settings.heading.label",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-new-arrivals.settings.text.label",
      "default": "The newest pieces to land in the collection, fresh off the rack and ready to wear."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.veylique-home-new-arrivals.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "t:sections.veylique-home-new-arrivals.settings.products_to_show.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-home-new-arrivals.settings.button_label.label",
      "default": "Shop Now"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "t:sections.veylique-home-new-arrivals.settings.aria_label.label",
      "default": "Veylique new arrivals"
    },
    {
      "type": "text",
      "id": "controls_label",
      "label": "t:sections.veylique-home-new-arrivals.settings.controls_label.label",
      "default": "Slider controls"
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "t:sections.veylique-home-new-arrivals.settings.previous_label.label",
      "default": "Previous slide"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "t:sections.veylique-home-new-arrivals.settings.next_label.label",
      "default": "Next slide"
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-new-arrivals.presets.name"
    }
  ]
}
{% endschema %}
