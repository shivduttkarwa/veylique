{% comment %}
  Search results — /search. Clean results page: prominent search field, result
  count, a responsive grid that renders products with the reusable product card
  and articles/pages as editorial cards, pagination, and an empty state.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

<section class="veylique-search-page veylique-page full-width" aria-labelledby="VeyliqueSearchTitle-{{ section.id }}">
  <div class="veylique-container">
    <header class="veylique-search-head">
      <p class="veylique-kicker">{{ 'search.eyebrow' | t }}</p>
      <h1 id="VeyliqueSearchTitle-{{ section.id }}" class="veylique-section-title veylique-search-title">{{ 'search.title' | t }}</h1>

      <form action="{{ routes.search_url }}" method="get" role="search" class="veylique-search-form">
        <span class="veylique-search-form__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          aria-label="{{ 'search.title' | t }}"
        >
        <button type="submit" class="veylique-button veylique-button--solid">{{ 'search.submit' | t }}</button>
      </form>
    </header>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <div class="veylique-search-empty">
          <h2 class="veylique-search-empty__title">{{ 'search.no_results_html' | t: terms: search.terms }}</h2>
          <p class="veylique-text">{{ 'search.empty_text' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="veylique-button veylique-button--solid">{{ 'search.browse_all' | t }}</a>
        </div>
      {%- else -%}
        <p class="veylique-search-count" aria-live="polite">{{ 'search.results_count' | t: count: search.results_count }}</p>

        {%- paginate search.results by section.settings.results_per_page -%}
          <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
            {%- for result in search.results -%}
              {%- case result.object_type -%}
                {%- when 'product' -%}
                  <div>
                    {% render 'veylique-home-product-card', product: result, show_brand: true, quick_add: true %}
                  </div>
                {%- else -%}
                  {%- liquid
                    assign result_image = result.featured_image | default: result.image
                    assign result_kicker = 'search.result_page' | t
                    if result.object_type == 'article'
                      assign result_kicker = 'search.result_article' | t
                    endif
                  -%}
                  <a class="veylique-search-card" href="{{ result.url }}">
                    <span class="veylique-search-card__media">
                      {%- if result_image -%}
                        {%- assign result_alt = result.title | escape -%}
                        {{ result_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', alt: result_alt, class: 'veylique-media' }}
                      {%- else -%}
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'veylique-media' }}
                      {%- endif -%}
                    </span>
                    <span class="veylique-search-card__body">
                      <span class="veylique-search-card__kicker">{{ result_kicker }}</span>
                      <span class="veylique-search-card__title">{{ result.title | escape }}</span>
                      {%- if result.excerpt != blank or result.content != blank -%}
                        <span class="veylique-search-card__excerpt">{{ result.excerpt | default: result.content | strip_html | truncatewords: 22 }}</span>
                      {%- endif -%}
                    </span>
                  </a>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="veylique-search-pagination" role="navigation" aria-label="{{ 'search.pagination' | t }}">
              {%- if paginate.previous -%}
                <a class="veylique-search-page-link" href="{{ paginate.previous.url }}" aria-label="{{ paginate.previous.title }}">‹</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a class="veylique-search-page-link" href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="veylique-search-page-link is-current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="veylique-search-page-gap">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a class="veylique-search-page-link" href="{{ paginate.next.url }}" aria-label="{{ paginate.next.title }}">›</a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .veylique-search-page { padding: clamp(6rem, 11vw, 9rem) 0 var(--veylique-section-spacing); }
  .veylique-search-head {
    max-width: 44rem;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
    text-align: center;
  }
  .veylique-search-title { margin: 0.5rem 0 1.75rem; }
  .veylique-search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    background: var(--veylique-color-surface, #fff);
    border: var(--veylique-border-width) solid var(--veylique-color-border);
    border-radius: var(--veylique-radius-pill);
    padding: 0.375rem 0.375rem 0.375rem 1rem;
  }
  .veylique-search-form__icon { display: inline-flex; color: var(--veylique-color-muted); }
  .veylique-search-form input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    padding: 0.75rem 0.25rem;
    font: inherit;
    font-size: 1rem;
    color: var(--veylique-color-foreground);
  }
  .veylique-search-form input:focus { outline: none; }
  .veylique-search-form .veylique-button { flex: 0 0 auto; white-space: nowrap; }

  .veylique-search-count {
    margin: 0 0 1.75rem;
    color: var(--veylique-color-muted);
    font-family: var(--veylique-font-body);
    font-size: 0.875rem;
  }

  .veylique-search-card { display: flex; flex-direction: column; color: inherit; text-decoration: none; }
  .veylique-search-card__media {
    aspect-ratio: 3 / 4;
    display: block;
    overflow: hidden;
    border-radius: var(--veylique-radius-md);
    background: var(--veylique-color-surface-alt);
  }
  .veylique-search-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 550ms ease; }
  @media (hover: hover) { .veylique-search-card:hover img { transform: scale(1.045); } }
  .veylique-search-card__body { display: flex; flex-direction: column; gap: 0.375rem; padding-top: 0.875rem; }
  .veylique-search-card__kicker {
    font-family: var(--veylique-font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--veylique-color-muted);
  }
  .veylique-search-card__title {
    font-family: var(--veylique-font-heading);
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--veylique-color-foreground);
  }
  .veylique-search-card__excerpt { font-size: 0.875rem; line-height: 1.6; color: var(--veylique-color-muted); }

  .veylique-search-empty { text-align: center; padding: clamp(2rem, 5vw, 4rem) 1rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .veylique-search-empty__title { margin: 0; font-family: var(--veylique-font-heading); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 500; }
  .veylique-search-empty .veylique-text { max-width: 32rem; }

  .veylique-search-pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }
  .veylique-search-page-link,
  .veylique-search-page-gap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    border-radius: var(--veylique-radius-sm);
    color: var(--veylique-color-foreground);
    font-family: var(--veylique-font-body);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
  }
  .veylique-search-page-link:hover { background: var(--veylique-color-surface-alt); }
  .veylique-search-page-link.is-current { background: var(--veylique-color-foreground); color: var(--veylique-color-background); }
  .veylique-search-page-gap { color: var(--veylique-color-muted); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "t:sections.search.settings.results_per_page.label",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.search.settings.columns_desktop.label",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
