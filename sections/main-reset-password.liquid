{% comment %}
  Reset password — reached from the email link Shopify sends after a customer
  requests a password recovery.
{% endcomment %}

<section class="vq-auth" aria-labelledby="ResetTitle-{{ section.id }}">
  {% render 'veylique-auth-aside',
    image: section.settings.image,
    fallback: section.settings.fallback,
    eyebrow: section.settings.aside_eyebrow,
    heading: section.settings.aside_heading,
    text: section.settings.aside_text
  %}

  <div class="vq-auth__panel">
    <div class="vq-auth__card">
      <div class="vq-auth__head">
        <span class="vq-auth__eyebrow">{{ 'customers.reset.eyebrow' | t }}</span>
        <h1 id="ResetTitle-{{ section.id }}" class="vq-auth__title">{{ 'customers.reset.title' | t }}</h1>
        <p class="vq-auth__subtitle">{{ 'customers.reset.subtitle' | t }}</p>
      </div>

      {% form 'reset_customer_password', class: 'vq-form' %}
        {% if form.errors %}
          <div class="vq-alert vq-alert--error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="vq-field">
          <label class="vq-label" for="ResetPassword-{{ section.id }}">{{ 'customers.reset.password' | t }}</label>
          <input
            type="password"
            class="vq-input"
            id="ResetPassword-{{ section.id }}"
            name="customer[password]"
            autocomplete="new-password"
            required
          >
        </div>

        <div class="vq-field">
          <label class="vq-label" for="ResetPasswordConfirm-{{ section.id }}">{{ 'customers.reset.password_confirm' | t }}</label>
          <input
            type="password"
            class="vq-input"
            id="ResetPasswordConfirm-{{ section.id }}"
            name="customer[password_confirmation]"
            autocomplete="new-password"
            required
          >
        </div>

        <button type="submit" class="veylique-btn btn-black veylique-btn--block">{{ 'customers.reset.submit' | t }}</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-reset-password.name",
  "settings": [
    { "type": "header", "content": "t:sections.main-login.settings.aside_header.content" },
    { "type": "image_picker", "id": "image", "label": "t:sections.main-login.settings.image.label" },
    { "type": "text", "id": "fallback", "label": "t:sections.main-login.settings.fallback.label", "default": "hero-2.webp" },
    { "type": "text", "id": "aside_eyebrow", "label": "t:sections.main-login.settings.aside_eyebrow.label", "default": "Veylique" },
    { "type": "text", "id": "aside_heading", "label": "t:sections.main-login.settings.aside_heading.label", "default": "A fresh start." },
    { "type": "text", "id": "aside_text", "label": "t:sections.main-login.settings.aside_text.label", "default": "Choose a new password and pick up right where you left off." }
  ]
}
{% endschema %}
