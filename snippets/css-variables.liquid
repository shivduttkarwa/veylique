{% style %}
  {% # Loads the Shopify font picker variants used by the theme with display: swap %}
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {% # Clash Display — the brand display face used for headings (ITF Free License). Self-hosted from /assets; the font-picker font remains the fallback. %}
  @font-face {
    font-family: 'Clash Display';
    src: url('{{ "clash-display-400.woff2" | asset_url }}') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Clash Display';
    src: url('{{ "clash-display-500.woff2" | asset_url }}') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Clash Display';
    src: url('{{ "clash-display-600.woff2" | asset_url }}') format('woff2');
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-heading--family: "Clash Display", {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-heading--style: {{ settings.type_heading_font.style }};
    --font-heading--weight: {{ settings.type_heading_font.weight }};
    --font-body--family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-body--style: {{ settings.type_body_font.style }};
    --font-body--weight: {{ settings.type_body_font.weight }};
    --font-primary--family: var(--font-body--family);
    --font-primary--style: var(--font-body--style);
    --font-primary--weight: var(--font-body--weight);
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --color-accent: {{ settings.accent_color }};
    --color-accent-foreground: {{ settings.accent_foreground_color }};
    --color-secondary-accent: {{ settings.secondary_accent_color }};
    --color-secondary-accent-foreground: {{ settings.secondary_accent_foreground_color }};
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;

    --veylique-font-heading: var(--font-heading--family);
    --veylique-font-heading-style: var(--font-heading--style);
    --veylique-font-heading-weight: var(--font-heading--weight);
    --veylique-font-body: var(--font-body--family);
    --veylique-font-body-style: var(--font-body--style);
    --veylique-font-body-weight: var(--font-body--weight);

    --veylique-color-background: var(--color-background);
    --veylique-color-foreground: var(--color-foreground);
    --veylique-color-surface: #ffffff;
    --veylique-color-surface-alt: #faf6ec;
    --veylique-color-muted: #756b60;
    --veylique-color-border: rgba(36, 31, 26, 0.14);
    --veylique-color-accent: var(--color-accent);
    --veylique-color-accent-foreground: var(--color-accent-foreground);
    --veylique-color-secondary: var(--color-secondary-accent);
    --veylique-color-secondary-foreground: var(--color-secondary-accent-foreground);
    --veylique-color-rose: #c58d80;

    --veylique-space-0: 0;
    --veylique-space-1: 0.25rem;
    --veylique-space-2: 0.5rem;
    --veylique-space-3: 0.75rem;
    --veylique-space-4: 1rem;
    --veylique-space-5: 1.25rem;
    --veylique-space-6: 1.5rem;
    --veylique-space-8: 2rem;
    --veylique-space-10: 2.5rem;
    --veylique-space-12: 3rem;
    --veylique-space-16: 4rem;
    --veylique-space-20: 5rem;
    --veylique-space-24: 6rem;
    --veylique-space-32: 8rem;

    --veylique-page-width: var(--page-width);
    --veylique-page-margin: var(--page-margin);
    --veylique-container-narrow: 48rem;
    --veylique-container: 92rem;
    --veylique-container-wide: 120rem;
    --veylique-container-full: 100%;
    --veylique-container-gutter: clamp(1rem, 3vw, 2.5rem);
    --veylique-section-spacing: clamp(4.5rem, 9vw, 9rem);

    --veylique-radius-xs: 0.25rem;
    --veylique-radius-sm: 0.5rem;
    --veylique-radius-md: 0.75rem;
    --veylique-radius-lg: 1rem;
    --veylique-radius-xl: 1.5rem;
    --veylique-radius-pill: 999rem;
    --veylique-border-width: 0.0625rem;

    --veylique-focus-ring-width: 0.125rem;
    --veylique-focus-ring-offset: 0.1875rem;
    --veylique-focus-ring-color: var(--veylique-color-foreground);

    --veylique-duration-fast: 180ms;
    --veylique-duration-base: 250ms;
    --veylique-duration-slow: 550ms;
    --veylique-ease-standard: cubic-bezier(0.22, 1, 0.36, 1);
    --veylique-ease-emphasized: cubic-bezier(0.19, 1, 0.22, 1);

    --veylique-z-header: 40;
    --veylique-z-overlay: 80;
    --veylique-z-skip-link: 10000;
  }
{% endstyle %}
