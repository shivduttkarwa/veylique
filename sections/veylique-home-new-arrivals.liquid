{% liquid
  assign first_slide = section.blocks.first
  assign first_text = first_slide.settings.text | default: 'Fresh off the rack - fluid silhouettes and considered fabrics for effortless, everyday style.'
  assign first_link = first_slide.settings.link | default: routes.all_products_collection_url
%}

<div class="veylique-arrivals-band full-width" data-veylique-arrivals>
  <div class="veylique-section-intro veylique-section-intro-js">
    <div class="veylique-container-wide">
      <h2 class="veylique-section-title">{{ section.settings.heading }}</h2>
      <p class="veylique-section-desc">{{ section.settings.text }}</p>
    </div>
  </div>

  <section class="veylique-slider-section" aria-label="{{ section.settings.aria_label | escape }}">
    <div class="veylique-slider-stage is-loading">
      <div class="veylique-slides">
        {% for block in section.blocks %}
          {% liquid
            assign slide_number = forloop.index | prepend: '0' | slice: -2, 2
            assign slide_link = block.settings.link | default: routes.all_products_collection_url
            assign slide_loading = 'lazy'
            assign slide_alt = block.settings.alt | default: block.settings.text
            if forloop.first
              assign slide_loading = 'eager'
            endif
          %}
          <div
            class="veylique-slide{% if forloop.first %} is-active{% elsif forloop.index == 2 %} is-next{% else %} is-hidden-right{% endif %}"
            data-veylique-arrivals-slide
            data-index="{{ forloop.index0 }}"
            data-number="{{ slide_number }}"
            data-text="{{ block.settings.text | escape }}"
            data-url="{{ slide_link }}"
            {{ block.shopify_attributes }}
          >
            <div class="veylique-slide-inner">
              {% render 'veylique-responsive-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                class: '',
                alt: slide_alt,
                width: 1200,
                height: 1500,
                loading: slide_loading
              %}
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="veylique-hit-area" aria-hidden="true">
        <button type="button" data-veylique-arrivals-dir="prev" aria-label="{{ section.settings.previous_label | escape }}"></button>
        <button type="button" data-veylique-arrivals-dir="next" aria-label="{{ section.settings.next_label | escape }}"></button>
      </div>

      <article class="veylique-content-card">
        <div class="veylique-card-body">
          <span class="veylique-slide-number veylique-reveal-js veylique-reveal--static-js" data-veylique-arrivals-number>01</span>
          <p class="veylique-card-text veylique-reveal-js veylique-reveal--static-js" data-veylique-arrivals-text>{{ first_text }}</p>
        </div>
        <a href="{{ first_link }}" class="veylique-card-button veylique-reveal-js veylique-reveal--static-js" data-veylique-arrivals-link>{{ section.settings.button_label }}</a>
      </article>

      <div class="veylique-mobile-arrows" aria-label="{{ section.settings.controls_label | escape }}">
        <button type="button" class="veylique-mobile-arrow veylique-mobile-arrow--prev" data-veylique-arrivals-dir="prev" aria-label="{{ section.settings.previous_label | escape }}"></button>
        <button type="button" class="veylique-mobile-arrow veylique-mobile-arrow--next" data-veylique-arrivals-dir="next" aria-label="{{ section.settings.next_label | escape }}"></button>
      </div>

      <div class="veylique-cursor-arrow" aria-hidden="true"></div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Veylique new arrivals",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The newest pieces to land in the collection, fresh off the rack and ready to wear."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Section accessibility label",
      "default": "Veylique new arrivals"
    },
    {
      "type": "text",
      "id": "controls_label",
      "label": "Controls accessibility label",
      "default": "Slider controls"
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "Previous button label",
      "default": "Previous slide"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "Next button label",
      "default": "Next slide"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "Fallback asset filename",
          "default": "hero-1.webp"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "default": "Veylique new arrival look"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Card text",
          "default": "Fresh off the rack - fluid silhouettes and considered fabrics for effortless, everyday style."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Veylique new arrivals",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
