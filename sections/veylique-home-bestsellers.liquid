<div class="veylique-section-intro veylique-section-intro-js full-width">
  <div class="veylique-container-wide">
    <div class="row">
      <div class="col-12 col-xl-10">
        <h2 id="VeyliqueBestsellersTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading }}</h2>
        <p class="veylique-section-desc">{{ section.settings.text }}</p>
      </div>
    </div>
  </div>
</div>

<section class="veylique-best-section full-width" aria-labelledby="VeyliqueBestsellersTitle-{{ section.id }}">
  <div class="veylique-best-inner">
    <div class="veylique-best-slider-area" data-veylique-card-slider>
      <div class="swiper veylique-best-swiper" tabindex="0" data-veylique-card-slider-viewport>
        <div class="swiper-wrapper" data-veylique-card-slider-track>
          {% for block in section.blocks %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              {% render 'veylique-home-product-card',
                variant: 'best',
                product: block.settings.product,
                title: block.settings.title,
                badge: block.settings.badge,
                price: block.settings.price,
                image: block.settings.image,
                hover_image: block.settings.hover_image,
                fallback: block.settings.fallback,
                hover_fallback: block.settings.hover_fallback,
                link: block.settings.link
              %}
            </div>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.show_navigation %}
        <div class="veylique-carousel-nav veylique-best-nav" aria-label="{{ section.settings.controls_label | escape }}">
          <button class="veylique-carousel-nav-btn veylique-best-nav-btn veylique-best-prev" type="button" data-veylique-card-slider-prev aria-label="{{ section.settings.previous_label | escape }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          </button>
          <button class="veylique-carousel-nav-btn veylique-best-nav-btn veylique-best-next" type="button" data-veylique-card-slider-next aria-label="{{ section.settings.next_label | escape }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-home-bestsellers.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-home-bestsellers.settings.heading.label",
      "default": "Shop Bestsellers"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-bestsellers.settings.text.label",
      "default": "Our most-loved styles, trusted by thousands worldwide."
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "t:sections.veylique-home-bestsellers.settings.show_navigation.label",
      "default": true
    },
    {
      "type": "text",
      "id": "controls_label",
      "label": "t:sections.veylique-home-bestsellers.settings.controls_label.label",
      "default": "Bestsellers carousel controls"
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "t:sections.veylique-home-bestsellers.settings.previous_label.label",
      "default": "Previous products"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "t:sections.veylique-home-bestsellers.settings.next_label.label",
      "default": "Next products"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "t:sections.veylique-home-bestsellers.blocks.product.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.product.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.image.label"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.hover_image.label"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.fallback.label",
          "default": "hero-1.webp"
        },
        {
          "type": "text",
          "id": "hover_fallback",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.hover_fallback.label",
          "default": "hero-2.webp"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.badge.label",
          "default": "Bestseller"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.title.label",
          "default": "Floral Wrap Midi Dress"
        },
        {
          "type": "text",
          "id": "price",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.price.label",
          "default": "$54.00"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.veylique-home-bestsellers.blocks.product.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-bestsellers.presets.name",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}
