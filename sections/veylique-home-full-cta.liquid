{% liquid
  assign cta_bg = section.settings.fallback | default: 'hero-1.webp' | asset_url
  assign cta_bg_mobile = section.settings.mobile_fallback | default: section.settings.fallback | default: 'hero-1.webp' | asset_url

  if section.settings.image != blank
    assign cta_bg = section.settings.image | image_url: width: 2400
  endif

  if section.settings.mobile_image != blank
    assign cta_bg_mobile = section.settings.mobile_image | image_url: width: 1400
  endif
%}

<section class="veylique-fullcta full-width" aria-label="{{ section.settings.aria_label | escape }}" style="--cta-bg: url('{{ cta_bg }}'); --cta-bg-mobile: url('{{ cta_bg_mobile }}');">
  <div class="veylique-fullcta-overlay"></div>
  <div class="veylique-fullcta-inner">
    <h2 class="veylique-fullcta-heading veylique-reveal-js veylique-reveal--static-js">{{ section.settings.heading }}</h2>
    <div class="veylique-fullcta-btns">
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="veylique-fullcta-btn veylique-reveal-js veylique-reveal--static-js">
        <span>{{ section.settings.button_label }}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veylique full CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "Accessibility label", "default": "Shop all products" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "fallback", "label": "Desktop fallback asset filename", "default": "hero-1.webp" },
    { "type": "text", "id": "mobile_fallback", "label": "Mobile fallback asset filename", "default": "hero-1.webp" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "For <em>every</em> size." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop All Products" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Veylique full CTA" }
  ]
}
{% endschema %}
