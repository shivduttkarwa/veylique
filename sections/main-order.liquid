{% comment %}
  Order detail — line items, totals and addresses for a single customer order.
{% endcomment %}

<section class="vq-account" aria-labelledby="OrderTitle-{{ section.id }}">
  <div class="vq-account__inner">
    <header class="vq-account__header">
      <div>
        <span class="vq-account__eyebrow">{{ 'customers.order.eyebrow' | t }}</span>
        <h1 id="OrderTitle-{{ section.id }}" class="vq-account__title">
          {{ 'customers.order.title' | t: name: order.name }}
        </h1>
        <p class="vq-auth__subtitle" style="margin-top:0.75rem">
          {{ 'customers.order.placed_on' | t: date: order.created_at | date: '%B %d, %Y' }}
        </p>
      </div>
      <div class="vq-account__actions">
        <a href="{{ routes.account_url }}" class="veylique-btn btn-white">{{ 'customers.order.back' | t }}</a>
      </div>
    </header>

    {% if order.cancelled %}
      <div class="vq-alert vq-alert--error" role="status" style="margin-bottom:1.5rem">
        <p>{{ 'customers.order.cancelled' | t: reason: order.cancel_reason_label }}</p>
      </div>
    {% endif %}

    <div class="vq-account__grid">
      {%- comment -%} ---- Line items + totals ---- {%- endcomment -%}
      <div class="vq-card">
        <div class="vq-table-wrap">
          <table class="vq-table">
            <thead>
              <tr>
                <th scope="col">{{ 'customers.order.item' | t }}</th>
                <th scope="col">{{ 'customers.order.price' | t }}</th>
                <th scope="col">{{ 'customers.order.quantity' | t }}</th>
                <th scope="col">{{ 'customers.order.total' | t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for line_item in order.line_items %}
                <tr>
                  <td>
                    <div class="vq-line">
                      {% if line_item.image %}
                        <img
                          class="vq-line__thumb"
                          src="{{ line_item.image | image_url: width: 140 }}"
                          alt="{{ line_item.title | escape }}"
                          width="56"
                          height="56"
                          loading="lazy"
                        >
                      {% else %}
                        <span class="vq-line__thumb" aria-hidden="true"></span>
                      {% endif %}
                      <div>
                        <a class="vq-line__title" href="{{ line_item.product.url }}">{{ line_item.title }}</a>
                        {% unless line_item.variant.title == 'Default Title' %}
                          <p class="vq-line__variant">{{ line_item.variant.title }}</p>
                        {% endunless %}
                      </div>
                    </div>
                  </td>
                  <td>{{ line_item.final_price | money }}</td>
                  <td>{{ line_item.quantity }}</td>
                  <td>{{ line_item.final_line_price | money }}</td>
                </tr>
              {% endfor %}
            </tbody>
            <tfoot>
              <tr>
                <td colspan="3">{{ 'customers.order.subtotal' | t }}</td>
                <td>{{ order.line_items_subtotal_price | money }}</td>
              </tr>
              {% for discount_application in order.discount_applications %}
                <tr>
                  <td colspan="3">{{ 'customers.order.discount' | t }} ({{ discount_application.title }})</td>
                  <td>−{{ discount_application.total_allocated_amount | money }}</td>
                </tr>
              {% endfor %}
              {% for shipping_method in order.shipping_methods %}
                <tr>
                  <td colspan="3">{{ 'customers.order.shipping' | t }} ({{ shipping_method.title }})</td>
                  <td>{{ shipping_method.price | money }}</td>
                </tr>
              {% endfor %}
              {% for tax_line in order.tax_lines %}
                <tr>
                  <td colspan="3">{{ 'customers.order.tax' | t }} ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)</td>
                  <td>{{ tax_line.price | money }}</td>
                </tr>
              {% endfor %}
              <tr>
                <td colspan="3">{{ 'customers.order.total' | t }}</td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

      {%- comment -%} ---- Status + addresses ---- {%- endcomment -%}
      <div>
        <div class="vq-card">
          <div class="vq-card__head">
            <h2 class="vq-card__title">{{ 'customers.order.status' | t }}</h2>
          </div>
          <p class="vq-meta-label">{{ 'customers.order.payment_status' | t }}</p>
          <p><span class="vq-pill vq-pill--{{ order.financial_status }}">{{ order.financial_status_label }}</span></p>
          <p class="vq-meta-label" style="margin-top:1.25rem">{{ 'customers.order.fulfillment_status' | t }}</p>
          <p><span class="vq-pill vq-pill--{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span></p>
        </div>

        {% if order.shipping_address %}
          <div class="vq-card">
            <div class="vq-card__head">
              <h2 class="vq-card__title">{{ 'customers.order.shipping_address' | t }}</h2>
            </div>
            <p class="vq-deflist">{{ order.shipping_address | format_address }}</p>
          </div>
        {% endif %}

        {% if order.billing_address %}
          <div class="vq-card">
            <div class="vq-card__head">
              <h2 class="vq-card__title">{{ 'customers.order.billing_address' | t }}</h2>
            </div>
            <p class="vq-deflist">{{ order.billing_address | format_address }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-order.name",
  "settings": []
}
{% endschema %}
