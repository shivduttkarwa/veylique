<div class="veylique-section-intro veylique-section-intro-js full-width">
  <div class="veylique-container-wide">
    <h2 class="veylique-section-title">{{ section.settings.heading }}</h2>
    <p class="veylique-section-desc">{{ section.settings.text }}</p>
  </div>
</div>

<section class="veylique-blog full-width" aria-label="{{ section.settings.heading | escape }}" data-veylique-blog>
  <div class="veylique-container-wide">
    <div class="veylique-blog-scroll">
      <div class="veylique-blog-sticky">
        {% for block in section.blocks %}
          <div class="veylique-blog-panel{% if forloop.first %} is-active{% endif %}" data-blog-panel="{{ forloop.index0 }}">
            <div class="veylique-blog-panel-media">
              {% render 'veylique-responsive-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                class: '',
                alt: block.settings.title,
                width: 1100,
                height: 1300
              %}
              <span class="veylique-blog-badge">{{ block.settings.badge }}</span>
            </div>
            <div class="veylique-blog-panel-body">
              <span class="veylique-blog-meta">{{ block.settings.meta }}</span>
              <h3 class="veylique-blog-panel-title">{{ block.settings.title }}</h3>
              <p class="veylique-blog-excerpt">{{ block.settings.excerpt }}</p>
              <a href="{{ block.settings.link | default: routes.root_url }}" class="veylique-blog-link">{{ section.settings.read_label }} <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="veylique-blog-rows">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link | default: routes.root_url }}" class="veylique-blog-scroll-row{% if forloop.first %} is-active{% endif %}" data-blog-row="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <span class="veylique-blog-row-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <span class="veylique-blog-row-thumb">
              {% render 'veylique-responsive-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                class: '',
                alt: block.settings.title,
                width: 180,
                height: 180
              %}
            </span>
            <span class="veylique-blog-row-content">
              <span class="veylique-blog-row-badge">{{ block.settings.badge }}</span>
              <span class="veylique-blog-row-title">{{ block.settings.title }}</span>
              <span class="veylique-blog-row-meta">{{ block.settings.meta }}</span>
            </span>
          </a>
        {% endfor %}

        {% if section.settings.button_label != blank %}
          <div class="veylique-blog-cta">
            <a href="{{ section.settings.button_link | default: routes.root_url }}" class="veylique-btn btn-black">{{ section.settings.button_label }}</a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-home-blog.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-home-blog.settings.heading.label",
      "default": "Recent Stories"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-blog.settings.text.label",
      "default": "Style guides, sizing notes, and a look behind the collections - straight from the studio."
    },
    {
      "type": "text",
      "id": "read_label",
      "label": "t:sections.veylique-home-blog.settings.read_label.label",
      "default": "Read Story"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-home-blog.settings.button_label.label",
      "default": "View All Articles"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-home-blog.settings.button_link.label"
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "t:sections.veylique-home-blog.blocks.story.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.image.label"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.fallback.label",
          "default": "hero-1.webp"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.badge.label",
          "default": "Style Guide"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.meta.label",
          "default": "12 Jul 2026 - 6 min read"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.title.label",
          "default": "The Ultimate Guide to Layering This Winter"
        },
        {
          "type": "textarea",
          "id": "excerpt",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.excerpt.label",
          "default": "From base layers to statement coats - how to build a cold-weather wardrobe that actually works for real days, not just lookbooks."
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.veylique-home-blog.blocks.story.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-blog.presets.name",
      "blocks": [
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        }
      ]
    }
  ]
}
{% endschema %}
