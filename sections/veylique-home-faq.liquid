<section class="veylique-home-faq full-width" aria-labelledby="veyliqueHomeFaqTitle-{{ section.id }}" data-veylique-home-faq>
  <span class="veylique-home-faq-glow" aria-hidden="true"></span>

  <div class="veylique-home-faq-inner">
    <div class="veylique-home-faq-copy">
      <p class="veylique-home-faq-kicker veylique-reveal-js veylique-reveal--static-js">{{ section.settings.kicker }}</p>
      <h2 id="veyliqueHomeFaqTitle-{{ section.id }}" class="veylique-home-faq-title veylique-reveal-js veylique-reveal--static-js">{{ section.settings.heading }}</h2>
      <p class="veylique-home-faq-text veylique-reveal-js veylique-reveal--static-js">{{ section.settings.text }}</p>

      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link | default: routes.root_url }}" class="veylique-home-faq-support veylique-reveal-js veylique-reveal--static-js">
          <span class="veylique-home-faq-support-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </span>
          <span class="veylique-home-faq-support-body">
            <span class="veylique-home-faq-support-link">
              {{ section.settings.link_label }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </span>
        </a>
      {% endif %}
    </div>

    <div class="veylique-home-faq-list">
      {% for block in section.blocks %}
        {% assign faq_num = forloop.index | prepend: '0' | slice: -2, 2 %}
        <div class="veylique-home-faq-item{% if forloop.first %} is-open{% endif %}" {{ block.shopify_attributes }}>
          <button
            class="veylique-home-faq-question"
            type="button"
            id="veyliqueHomeFaqQ-{{ section.id }}-{{ forloop.index }}"
            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="veyliqueHomeFaqA-{{ section.id }}-{{ forloop.index }}"
          >
            <span class="veylique-home-faq-num" aria-hidden="true">{{ faq_num }}</span>
            <span class="veylique-home-faq-q-text">{{ block.settings.question }}</span>
            <span class="veylique-home-faq-icon" aria-hidden="true"></span>
          </button>
          <div class="veylique-home-faq-answer" id="veyliqueHomeFaqA-{{ section.id }}-{{ forloop.index }}" role="region" aria-labelledby="veyliqueHomeFaqQ-{{ section.id }}-{{ forloop.index }}">
            <div class="veylique-home-faq-answer-inner">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .veylique-home-faq {
    position: relative;
    overflow: hidden;
    border-top: 0.0625rem solid rgba(42, 35, 24, 0.08);
    background:
      radial-gradient(120% 80% at 100% 0%, rgba(166, 94, 85, 0.07), transparent 55%),
      #f6f2ea;
    color: var(--mustard-text, #241816);
    padding: clamp(4.5rem, 8vw, 7.5rem) 0;
  }

  /* Soft accent glow that drifts for depth. */
  .veylique-home-faq-glow {
    position: absolute;
    top: -18%;
    right: -12%;
    z-index: 0;
    width: min(42rem, 70vw);
    height: min(42rem, 70vw);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(166, 94, 85, 0.16), transparent 62%);
    filter: blur(10px);
    pointer-events: none;
    animation: veylique-home-faq-drift 18s ease-in-out infinite alternate;
  }
  @keyframes veylique-home-faq-drift {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(-3rem, 2.5rem, 0) scale(1.08); }
  }
  @media (prefers-reduced-motion: reduce) {
    .veylique-home-faq-glow { animation: none; }
  }

  .veylique-home-faq-inner {
    position: relative;
    z-index: 1;
    width: min(100% - 3rem, var(--mustard-container, 92rem));
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    align-items: start;
    gap: clamp(2.5rem, 6vw, 5.5rem);
  }

  /* ---- Left copy ---- */
  .veylique-home-faq-copy {
    position: sticky;
    top: 6rem;
    max-width: 30rem;
  }

  .veylique-home-faq-kicker {
    display: inline-flex;
    align-items: center;
    margin: 0 0 1.25rem;
    padding: 0.4375rem 0.875rem;
    border-radius: 999px;
    background: rgba(166, 94, 85, 0.1);
    color: var(--mustard-accent-dark, #a65e55);
    font-family: var(--mustard-font-mono, monospace);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .veylique-home-faq-title {
    margin: 0;
    font-family: var(--mustard-font-heading, serif);
    font-size: clamp(2.35rem, 5.2vw, 4.5rem);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.045em;
  }

  .veylique-home-faq-text {
    max-width: 24rem;
    margin: 1.25rem 0 0;
    color: var(--mustard-muted, #756b60);
    font-family: var(--mustard-font-body, sans-serif);
    font-size: 0.9688rem;
    line-height: 1.75;
  }

  /* Glassy support card */
  .veylique-home-faq-support {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    margin-top: 2.25rem;
    padding: 0.875rem 1.25rem 0.875rem 0.875rem;
    border: 0.0625rem solid var(--mustard-border, rgba(36, 24, 22, 0.14));
    border-radius: var(--veylique-radius-pill, 999rem);
    background: rgba(255, 255, 255, 0.7);
    -webkit-backdrop-filter: blur(0.5rem);
    backdrop-filter: blur(0.5rem);
    color: var(--mustard-text, #241816);
    text-decoration: none;
    transition: transform 0.28s var(--mustard-ease, cubic-bezier(0.22, 1, 0.36, 1)), box-shadow 0.28s ease, border-color 0.28s ease;
  }
  .veylique-home-faq-support-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--mustard-accent-dark, #a65e55);
    color: #faf6ec;
  }
  .veylique-home-faq-support-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    font-family: var(--mustard-font-body, sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .veylique-home-faq-support-link svg { transition: transform 0.25s ease; }
  @media (hover: hover) {
    .veylique-home-faq-support:hover {
      transform: translateY(-0.1875rem);
      border-color: var(--mustard-accent-dark, #a65e55);
      box-shadow: 0 1rem 2.25rem rgba(36, 24, 22, 0.12);
    }
    .veylique-home-faq-support:hover .veylique-home-faq-support-link svg { transform: translateX(0.1875rem); }
  }

  /* ---- Accordion cards ---- */
  .veylique-home-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .veylique-home-faq-item {
    position: relative;
    border: 0.0625rem solid var(--mustard-border, rgba(36, 24, 22, 0.12));
    border-radius: var(--veylique-radius-lg, 1rem);
    background: rgba(255, 255, 255, 0.55);
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s var(--mustard-ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  /* Cursor spotlight (set by JS via --mx/--my). */
  .veylique-home-faq-item::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: radial-gradient(16rem 16rem at var(--mx, 50%) var(--my, -20%), rgba(166, 94, 85, 0.12), transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .veylique-home-faq-item:hover {
      border-color: rgba(166, 94, 85, 0.4);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 1rem 2.5rem rgba(36, 24, 22, 0.09);
    }
    .veylique-home-faq-item:hover::before { opacity: 1; }
  }

  .veylique-home-faq-item.is-open {
    border-color: rgba(166, 94, 85, 0.45);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1.25rem 3rem rgba(36, 24, 22, 0.1);
  }

  .veylique-home-faq-question {
    position: relative;
    z-index: 1;
    width: 100%;
    display: grid;
    grid-template-columns: 2.75rem minmax(0, 1fr) 2.5rem;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 1.5rem 1.5rem 1.375rem;
    border: 0;
    background: transparent;
    color: var(--mustard-text, #241816);
    cursor: pointer;
    text-align: left;
  }

  .veylique-home-faq-num {
    font-family: var(--mustard-font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--mustard-accent-dark, #a65e55);
    opacity: 0.6;
    transition: opacity 0.25s ease;
  }
  .veylique-home-faq-item.is-open .veylique-home-faq-num { opacity: 1; }

  .veylique-home-faq-q-text {
    font-family: var(--mustard-font-heading, serif);
    font-size: clamp(1.0625rem, 1.6vw, 1.375rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  /* Morphing +/x icon in a circle */
  .veylique-home-faq-icon {
    position: relative;
    width: 2.5rem;
    height: 2.5rem;
    flex: 0 0 auto;
    border: 0.0625rem solid rgba(42, 35, 24, 0.2);
    border-radius: 50%;
    color: var(--mustard-text, #241816);
    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.4s var(--mustard-ease, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .veylique-home-faq-icon::before,
  .veylique-home-faq-icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0.8125rem;
    height: 0.09375rem;
    border-radius: 999px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.35s var(--mustard-ease, cubic-bezier(0.22, 1, 0.36, 1)), opacity 0.25s ease;
  }
  .veylique-home-faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); }

  .veylique-home-faq-item.is-open .veylique-home-faq-icon {
    background: var(--mustard-accent-dark, #a65e55);
    border-color: var(--mustard-accent-dark, #a65e55);
    color: #faf6ec;
    transform: rotate(135deg);
  }
  .veylique-home-faq-item.is-open .veylique-home-faq-icon::after { opacity: 0; }

  /* Answer reveal */
  .veylique-home-faq-answer {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.42s var(--mustard-ease, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .veylique-home-faq-item.is-open .veylique-home-faq-answer {
    grid-template-rows: 1fr;
  }

  .veylique-home-faq-answer-inner {
    overflow: hidden;
    padding-left: 3.75rem;
    padding-right: 1.5rem;
  }

  .veylique-home-faq-answer-inner p {
    max-width: 40rem;
    margin: 0;
    padding: 0.25rem 0 1.625rem;
    border-top: 0.0625rem solid rgba(166, 94, 85, 0.16);
    padding-top: 1.25rem;
    color: var(--mustard-muted, #756b60);
    font-family: var(--mustard-font-body, sans-serif);
    font-size: 0.9375rem;
    line-height: 1.78;
    opacity: 0;
    transform: translateY(0.375rem);
    transition: opacity 0.35s ease 0.08s, transform 0.4s var(--mustard-ease, cubic-bezier(0.22, 1, 0.36, 1)) 0.08s;
  }
  .veylique-home-faq-item.is-open .veylique-home-faq-answer-inner p {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 991.98px) {
    .veylique-home-faq-inner {
      grid-template-columns: 1fr;
    }
    .veylique-home-faq-copy {
      position: static;
      max-width: 34rem;
    }
  }

  @media (max-width: 576px) {
    .veylique-home-faq {
      padding: 3.5rem 0;
    }
    .veylique-home-faq-inner {
      width: min(100% - 2.25rem, var(--mustard-container, 92rem));
      gap: 2.25rem;
    }
    .veylique-home-faq-question {
      grid-template-columns: 2rem minmax(0, 1fr) 2.25rem;
      gap: 0.75rem;
      padding: 1.25rem 1.125rem;
    }
    .veylique-home-faq-num { display: none; }
    .veylique-home-faq-icon { width: 2.25rem; height: 2.25rem; }
    .veylique-home-faq-answer-inner {
      padding-left: 1.125rem;
      padding-right: 1.125rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.veylique-home-faq.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-home-faq.settings.kicker.label",
      "default": "Help Desk"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-home-faq.settings.heading.label",
      "default": "Questions, answered"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-faq.settings.text.label",
      "default": "Everything you need before checkout, from fit to delivery and easy exchanges."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "t:sections.veylique-home-faq.settings.link_label.label",
      "default": "Talk to support"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.veylique-home-faq.settings.link.label"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "t:sections.veylique-home-faq.blocks.question.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.veylique-home-faq.blocks.question.settings.question.label",
          "default": "How long does delivery take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "t:sections.veylique-home-faq.blocks.question.settings.answer.label",
          "default": "Most orders ship within 24-48 hours. Standard delivery usually arrives in 3-6 business days, depending on your location."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-faq.presets.name",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
