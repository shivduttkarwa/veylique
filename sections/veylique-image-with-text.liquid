<section class="veylique-page veylique-section" aria-labelledby="VeyliqueEditorialTitle-{{ section.id }}">
  <div class="veylique-container veylique-editorial">
    <div class="veylique-editorial__media">
      {% render 'veylique-responsive-image',
        image: section.settings.image,
        fallback: section.settings.fallback,
        class: 'veylique-media',
        alt: section.settings.heading,
        width: 1400
      %}
    </div>
    <div>
      <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
      <h2 id="VeyliqueEditorialTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading }}</h2>
      <p class="veylique-text">{{ section.settings.text }}</p>
      {% if section.settings.button_label != blank %}
        <a class="veylique-button veylique-button--solid" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-image-with-text.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.veylique-image-with-text.settings.image.label"
    },
    {
      "type": "text",
      "id": "fallback",
      "label": "t:sections.veylique-image-with-text.settings.fallback.label",
      "default": "manifest-cta.jpg"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-image-with-text.settings.kicker.label",
      "default": "The curated edit"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.veylique-image-with-text.settings.heading.label",
      "default": "Everyday polish, softened for comfort"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "t:sections.veylique-image-with-text.settings.text.label",
      "default": "Use this editorial module for a campaign story, founder note, or seasonal look that anchors the collection."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-image-with-text.settings.button_label.label",
      "default": "Explore the edit"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-image-with-text.settings.button_link.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-image-with-text.presets.name"
    }
  ]
}
{% endschema %}
