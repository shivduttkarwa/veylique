<div class="veylique-section-intro veylique-section-intro-js full-width">
  <div class="veylique-container-wide">
    <h2 class="veylique-section-title">{{ section.settings.heading }}</h2>
    <p class="veylique-section-desc">{{ section.settings.text }}</p>
  </div>
</div>

<section class="veylique-curated full-width" aria-label="{{ section.settings.heading | escape }}">
  <div class="veylique-curated-row">
    {% for block in section.blocks limit: 2 %}
      {% liquid
        assign tile_title = block.settings.title
        assign tile_price = block.settings.price
        assign tile_link = block.settings.link | default: routes.all_products_collection_url
        assign tile_image = block.settings.image
        if block.settings.product != blank
          assign tile_title = block.settings.product.title
          assign tile_price = block.settings.product.price | money
          assign tile_link = block.settings.product.url
          assign tile_image = block.settings.product.featured_image
        endif
      %}
      <a class="veylique-product-tile" href="{{ tile_link }}" {{ block.shopify_attributes }}>
        <div class="veylique-product-image-wrap">
          {% render 'veylique-responsive-image',
            image: tile_image,
            fallback: block.settings.fallback,
            class: 'veylique-product-image',
            alt: tile_title,
            width: 1200,
            height: 1500
          %}
        </div>
        <div class="veylique-bottom-overlay"></div>
        <div class="veylique-product-info">
          <div class="veylique-product-meta">
            <h3 class="veylique-product-name">{{ tile_title }}</h3>
            <p class="veylique-product-price">{{ tile_price }}</p>
            <p class="veylique-product-desc">{{ block.settings.description }}</p>
          </div>
          <div class="veylique-buy-wrap">
            <span class="veylique-btn btn-white">{{ section.settings.button_label }}</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Veylique curated edit",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Everyday Edit"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Handpicked essentials for a versatile, easy-to-style wardrobe."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Product tile",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "Fallback asset filename",
          "default": "hero-1.webp"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Fallback title",
          "default": "Mustard Wrap Midi Dress"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Fallback price",
          "default": "$68.00"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A fluid wrap dress in breathable viscose, cut for effortless everyday movement."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Veylique curated edit",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
