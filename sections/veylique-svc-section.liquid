<section class="veylique-svc-section full-width" aria-label="{{ section.settings.heading | escape }}">
  <div class="veylique-section-intro veylique-section-intro-js veylique-section-intro--flush">
    <div class="veylique-container-wide container-fluid">
      <div class="row">
        <div class="col-12 col-xl-10">
          {%- if section.settings.eyebrow != blank -%}
            <span class="veylique-eyebrow">{{ section.settings.eyebrow | escape }}</span>
          {%- endif -%}
          <h2 class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
          {%- if section.settings.text != blank -%}
            <p class="veylique-section-desc">{{ section.settings.text | escape }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <div class="veylique-container-wide">
    <ul class="veylique-svc-cards">
      {%- for block in section.blocks -%}
        <li class="veylique-svc-cell veylique-reveal-js veylique-reveal--fade-js" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" class="veylique-svc-card-link">
            <div class="veylique-svc-card">
              <div class="veylique-svc-card-top">
                <span class="veylique-svc-icon">{% render 'veylique-svc-icon', icon: block.settings.icon %}</span>
                <span class="veylique-svc-meta">{{ block.settings.meta | escape }}</span>
              </div>
              <div class="veylique-svc-card-body">
                <h3 class="veylique-svc-title">{{ block.settings.title | escape }}</h3>
                <p class="veylique-svc-desc">{{ block.settings.desc | escape }}</p>
                {%- if section.settings.more_label != blank -%}
                  <span class="veylique-svc-more">
                    {{ section.settings.more_label | escape }}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                {%- endif -%}
              </div>
            </div>

            <div class="veylique-svc-photos" aria-hidden="true">
              <div class="veylique-svc-photo veylique-svc-photo--first">
                {% render 'veylique-responsive-image', image: block.settings.image_1, fallback: block.settings.fallback_1, width: 600, height: 400 %}
              </div>
              <div class="veylique-svc-photo veylique-svc-photo--second">
                {% render 'veylique-responsive-image', image: block.settings.image_2, fallback: block.settings.fallback_2, width: 600, height: 400 %}
              </div>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
  .veylique-svc-section {
    --svc-card-lift: -2.5rem;
    --svc-card-tilt: -2deg;
    --svc-photo-drop: 135%;
    --svc-photo-spread: 50%;
    --svc-photo-tilt-1: -15deg;
    --svc-photo-tilt-2: 12deg;
    --svc-photo-size: min(76.8%, 16.2rem);
    --svc-speed: 0.5s;
    --svc-ease: cubic-bezier(0.7, 0, 0.3, 1);
    --svc-ease-back: cubic-bezier(0.34, 1.9, 0.64, 1);

    background: var(--mustard-bg);
    padding: 0 0 12rem;
    overflow: hidden;
  }

  .veylique-svc-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.875rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .veylique-svc-cell { min-width: 0; position: relative; }
  .veylique-svc-cell:hover { z-index: 3; }

  .veylique-svc-card-link {
    position: relative;
    z-index: 1;
    display: flex;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }
  .veylique-svc-card-link:hover { z-index: 2; }

  .veylique-svc-card {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 4.5rem;
    width: 100%;
    min-height: 21rem;
    padding: 1.75rem;
    background: var(--mustard-surface);
    border: 0.0625rem solid var(--mustard-border);
    border-radius: var(--mustard-radius);
    transition:
      transform var(--svc-speed) var(--svc-ease),
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }
  .veylique-svc-card-link:hover .veylique-svc-card {
    transform: translate3d(0, var(--svc-card-lift), 0) rotateZ(var(--svc-card-tilt));
    transition-timing-function: var(--svc-ease-back), ease, ease;
    border-color: var(--mustard-accent-dark);
    box-shadow:
      0 0.125rem 0.375rem rgba(36, 24, 22, 0.08),
      0 0.375rem 1rem rgba(36, 24, 22, 0.08),
      0 0.75rem 2.25rem rgba(36, 24, 22, 0.12);
  }

  .veylique-svc-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .veylique-svc-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: rgba(166, 94, 85, 0.1);
    color: var(--mustard-accent-dark);
    transition: background-color 0.35s ease, color 0.35s ease;
  }
  .veylique-svc-icon svg { width: 1.5rem; height: 1.5rem; }
  .veylique-svc-card-link:hover .veylique-svc-icon {
    background: var(--mustard-accent-dark);
    color: #faf6ec;
  }

  .veylique-svc-meta {
    font-family: "Courier New", monospace;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mustard-muted);
    padding-top: 0.375rem;
    white-space: nowrap;
  }

  .veylique-svc-card-body { display: flex; flex-direction: column; gap: 0.625rem; }
  .veylique-svc-title {
    margin: 0;
    max-width: 85%;
    font-family: "Clash Display", "Times New Roman", serif;
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--mustard-text);
  }
  .veylique-svc-desc {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--mustard-muted);
  }
  .veylique-svc-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--mustard-accent-dark);
    opacity: 0;
    transform: translateY(0.375rem);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .veylique-svc-card-link:hover .veylique-svc-more { opacity: 1; transform: translateY(0); }

  .veylique-svc-photos {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .veylique-svc-photo {
    position: absolute;
    width: var(--svc-photo-size);
    aspect-ratio: 3 / 2;
    transition: transform var(--svc-speed) var(--svc-ease);
  }
  .veylique-svc-photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    border: 0.125rem solid rgba(255, 255, 255, 0.5);
    box-shadow:
      0 0.5rem 1.25rem rgba(20, 12, 10, 0.28),
      0 1.5rem 3.25rem rgba(20, 12, 10, 0.38);
    transition: transform var(--svc-speed) var(--svc-ease);
  }
  .veylique-svc-card-link:hover .veylique-svc-photo,
  .veylique-svc-card-link:hover .veylique-svc-photo img {
    transition-timing-function: var(--svc-ease-back);
  }
  .veylique-svc-card-link:hover .veylique-svc-photo--first {
    transform:
      translate3d(calc(-1 * var(--svc-photo-spread)), var(--svc-photo-drop), 0)
      rotateZ(var(--svc-photo-tilt-1));
  }
  .veylique-svc-card-link:hover .veylique-svc-photo--second {
    transform:
      translate3d(var(--svc-photo-spread), var(--svc-photo-drop), 0)
      rotateZ(var(--svc-photo-tilt-2));
    z-index: 2;
  }

  @media (hover: none) {
    .veylique-svc-photos { display: none; }
  }
  @media (max-width: 991px) {
    .veylique-svc-section { padding: 0 0 8rem; }
    .veylique-svc-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .veylique-svc-section { padding: 0 0 5rem; }
    .veylique-svc-cards { grid-template-columns: 1fr; }
    .veylique-svc-card { min-height: 0; gap: 3rem; }
    .veylique-svc-title { max-width: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.veylique-svc-section.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.veylique-svc-section.settings.eyebrow.label",
      "default": "Our Expertise"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-svc-section.settings.heading.label",
      "default": "What We Do"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-svc-section.settings.text.label",
      "default": "Services designed around your wardrobe — from first consultation to outfits you keep reaching for."
    },
    {
      "type": "text",
      "id": "more_label",
      "label": "t:sections.veylique-svc-section.settings.more_label.label",
      "default": "Book this service"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "t:sections.veylique-svc-section.blocks.service.name",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.icon.label",
          "options": [
            { "value": "styling", "label": "Styling" },
            { "value": "wardrobe", "label": "Wardrobe" },
            { "value": "occasion", "label": "Occasion" },
            { "value": "fit", "label": "Fit" },
            { "value": "bridal", "label": "Bridal" },
            { "value": "virtual", "label": "Virtual" }
          ],
          "default": "styling"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.meta.label",
          "default": "60 min · from $90"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.title.label",
          "default": "Personal Styling Consultation"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.desc.label",
          "default": "A one-on-one session to understand your fit preferences, lifestyle, colour comfort, and everyday outfit goals."
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.link.label"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.image_1.label"
        },
        {
          "type": "text",
          "id": "fallback_1",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.fallback_1.label",
          "default": "service-1-consult-1.jpg"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.image_2.label"
        },
        {
          "type": "text",
          "id": "fallback_2",
          "label": "t:sections.veylique-svc-section.blocks.service.settings.fallback_2.label",
          "default": "service-1-consult-2.jpg"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-svc-section.presets.name",
      "blocks": [
        { "type": "service", "settings": { "icon": "styling", "meta": "60 min · from $90", "title": "Personal Styling Consultation", "desc": "A one-on-one session to understand your fit preferences, lifestyle, colour comfort, and everyday outfit goals.", "fallback_1": "service-1-consult-1.jpg", "fallback_2": "service-1-consult-2.jpg" } },
        { "type": "service", "settings": { "icon": "wardrobe", "meta": "45 min · from $120", "title": "Wardrobe Edit & Outfit Planning", "desc": "A practical edit of what to keep, what to pair, and which missing pieces will make getting dressed easier.", "fallback_1": "service-2-consult-1.jpg", "fallback_2": "service-2-consult-2.jpg" } },
        { "type": "service", "settings": { "icon": "occasion", "meta": "75 min · from $150", "title": "Occasion Dressing Session", "desc": "Looks for weddings, festive days, work events, and travel, styled with comfort, proportion, and repeat wear in mind.", "fallback_1": "service-3-consult-1.jpg", "fallback_2": "service-3-consult-2.jpg" } },
        { "type": "service", "settings": { "icon": "fit", "meta": "30 min · from $70", "title": "Fit & Size Guidance", "desc": "Measurements, silhouette notes, and fabric guidance to help you choose the right size before you order.", "fallback_1": "service-4-consult-1.jpg", "fallback_2": "service-4-consult-2.jpg" } },
        { "type": "service", "settings": { "icon": "bridal", "meta": "12 weeks · from $480", "title": "Bridal & Event Styling", "desc": "A focused styling programme for ceremonies, parties, and milestone moments, planned look by look.", "fallback_1": "service-5-consult-1.jpg", "fallback_2": "service-5-consult-2.jpg" } },
        { "type": "service", "settings": { "icon": "virtual", "meta": "30 min · from $50", "title": "Virtual Style Coaching", "desc": "Expert guidance from anywhere, with seasonal check-ins to keep your wardrobe feeling current and useful.", "fallback_1": "service-6-consult-2.jpg", "fallback_2": "service-6-consult-1.jpg" } }
      ]
    }
  ]
}
{% endschema %}
