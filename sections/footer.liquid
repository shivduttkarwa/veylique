{% liquid
  assign footer_menu = section.settings.menu
  assign legal_menu = section.settings.legal_menu
  assign cta_url = section.settings.cta_link | default: routes.all_products_collection_url
%}

<footer class="veylique-footer full-width" role="contentinfo" data-veylique-footer>
  <div class="veylique-footer-main">
    <div class="veylique-footer-inner">
      <div class="veylique-footer-col veylique-footer-col--cta">
        {% if section.settings.headline != blank %}
          <p class="veylique-footer-headline">{{ section.settings.headline | escape }}</p>
        {% endif %}

        {% if section.settings.cta_label != blank %}
          <a href="{{ cta_url }}" class="veylique-footer-cta-btn">
            <span>{{ section.settings.cta_label | escape }}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
        {% endif %}

        <p class="veylique-footer-copy">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}
          {% if section.settings.copy_suffix != blank %}
            &middot; {{ section.settings.copy_suffix | escape }}
          {% endif %}
        </p>

        <nav class="veylique-footer-legal" aria-label="{{ section.settings.legal_label | escape }}">
          {% if legal_menu.links.size > 0 %}
            {% for link in legal_menu.links %}
              <a href="{{ link.url }}">{{ link.title | escape }}</a>
            {% endfor %}
          {% endif %}
        </nav>

        {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
          <div class="veylique-footer-payment" aria-label="{{ section.settings.payment_label | escape }}">
            {% for type in shop.enabled_payment_types %}
              {{ type | payment_type_svg_tag }}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <nav class="veylique-footer-col veylique-footer-col--nav" aria-label="{{ section.settings.menu_label | escape }}">
        <ul class="veylique-footer-menu">
          {% if footer_menu.links.size > 0 %}
            {% for link in footer_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="{{ routes.root_url }}">Home</a></li>
            <li><a href="{{ routes.all_products_collection_url }}">Shop</a></li>
            <li><a href="/pages/about">About</a></li>
            <li><a href="/pages/services">Services</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          {% endif %}
        </ul>
      </nav>

      <div class="veylique-footer-col veylique-footer-col--connect">
        {% if section.settings.connect_heading != blank %}
          <h2 class="veylique-footer-connect-h">{{ section.settings.connect_heading | escape }}</h2>
        {% endif %}

        {% if section.settings.address != blank %}
          <p class="veylique-footer-address">{{ section.settings.address | newline_to_br }}</p>
        {% endif %}

        {% if section.settings.email != blank %}
          <a class="veylique-footer-email" href="mailto:{{ section.settings.email | escape }}">{{ section.settings.email | escape }}</a>
        {% endif %}

        {% if section.settings.show_newsletter %}
          {% form 'customer', class: 'veylique-footer-newsletter' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <label for="VeyliqueFooterEmail-{{ section.id }}" class="veylique-footer-newsletter-label">
              {{ section.settings.newsletter_label | escape }}
            </label>
            <div class="veylique-footer-newsletter-row">
              <input
                id="VeyliqueFooterEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                placeholder="{{ section.settings.newsletter_placeholder | escape }}"
                required
              >
              <button type="submit" aria-label="{{ section.settings.newsletter_button_label | escape }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </button>
            </div>
            {% if form.posted_successfully? %}
              <p class="veylique-footer-newsletter-message">{{ section.settings.newsletter_success | escape }}</p>
            {% endif %}
            {% if form.errors %}
              <div class="veylique-footer-newsletter-message">{{ form.errors | default_errors }}</div>
            {% endif %}
          {% endform %}
        {% endif %}

        <div class="veylique-footer-social">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" aria-label="{{ section.settings.instagram_label | escape }}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"></circle>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" aria-label="{{ section.settings.tiktok_label | escape }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.22 8.22 0 0 0 4.84 1.55V6.79a4.85 4.85 0 0 1-1.07-.1z"></path>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.pinterest_url != blank %}
            <a href="{{ section.settings.pinterest_url }}" aria-label="{{ section.settings.pinterest_label | escape }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"></path>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="veylique-footer-brand" aria-hidden="true">
    <div class="veylique-footer-brand-text">{{ section.settings.brand_text | default: shop.name | escape }}</div>
    <div class="veylique-footer-brand-media">
      {% render 'veylique-responsive-image',
        image: section.settings.brand_image,
        fallback: 'cta.webp',
        class: 'veylique-media',
        alt: '',
        width: 2200,
        height: 1200
      %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .veylique-footer {
    overflow: hidden;
    background: #0a0a08;
    color: #faf6ec;
  }

  .veylique-footer-main {
    border-bottom: 0.0625rem solid rgba(255, 250, 247, 0.08);
    padding: 4.5rem 0 3rem;
  }

  .veylique-footer-inner {
    width: min(100% - 4rem, 92rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(12rem, 0.6fr) minmax(16rem, 0.7fr);
    align-items: start;
    gap: 3rem 4rem;
    margin-inline: auto;
  }

  .veylique-footer-col--cta,
  .veylique-footer-col--connect {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .veylique-footer-col--cta {
    gap: 1.75rem;
  }

  .veylique-footer-headline {
    max-width: 22rem;
    margin: 0;
    color: #faf6ec;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: clamp(1.5rem, 2.4vw, 2.25rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.15;
  }

  .veylique-footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 0.0625rem solid rgba(255, 250, 247, 0.35);
    border-radius: 0.25rem;
    padding: 0.75rem 1.5rem;
    color: #faf6ec;
    font-family: var(--font-heading--family);
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .veylique-footer-cta-btn:hover {
    border-color: rgba(255, 250, 247, 0.6);
    background: rgba(255, 250, 247, 0.08);
    transform: translateY(-0.0625rem);
  }

  .veylique-footer-copy {
    margin: 0;
    color: rgba(255, 250, 247, 0.35);
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
  }

  .veylique-footer-legal,
  .veylique-footer-payment,
  .veylique-footer-social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
  }

  .veylique-footer-legal a {
    color: rgba(255, 250, 247, 0.35);
    font-size: 0.75rem;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .veylique-footer-legal a:hover {
    color: rgba(255, 250, 247, 0.72);
  }

  .veylique-footer-payment svg {
    width: 2.25rem;
    height: auto;
    border-radius: 0.1875rem;
  }

  .veylique-footer-menu {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .veylique-footer-menu a {
    color: rgba(255, 250, 247, 0.65);
    font-family: var(--font-heading--family);
    font-size: 1.0625rem;
    font-weight: 400;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .veylique-footer-menu a:hover {
    color: #faf6ec;
  }

  .veylique-footer-connect-h {
    margin: 0;
    color: #faf6ec;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0;
  }

  .veylique-footer-address,
  .veylique-footer-email {
    margin: 0;
    color: rgba(255, 250, 247, 0.55);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .veylique-footer-email {
    text-decoration: none;
  }

  .veylique-footer-email:hover,
  .veylique-footer-social a:hover {
    color: #faf6ec;
  }

  .veylique-footer-newsletter {
    width: 100%;
    display: grid;
    gap: 0.6rem;
    margin-top: 0.35rem;
  }

  .veylique-footer-newsletter-label {
    color: rgba(255, 250, 247, 0.68);
    font-family: var(--font-heading--family);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .veylique-footer-newsletter-row {
    display: flex;
    align-items: center;
    border-bottom: 0.0625rem solid rgba(255, 250, 247, 0.24);
  }

  .veylique-footer-newsletter-row input {
    min-width: 0;
    flex: 1;
    border: 0;
    padding: 0.8rem 0;
    background: transparent;
    color: #faf6ec;
    font: inherit;
  }

  .veylique-footer-newsletter-row input::placeholder {
    color: rgba(255, 250, 247, 0.35);
  }

  .veylique-footer-newsletter-row button {
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: 999rem;
    background: transparent;
    color: rgba(255, 250, 247, 0.72);
    cursor: pointer;
  }

  .veylique-footer-newsletter-message {
    margin: 0;
    color: rgba(255, 250, 247, 0.62);
    font-size: 0.8125rem;
    line-height: 1.45;
  }

  .veylique-footer-social {
    gap: 1.125rem;
    margin-top: 0.25rem;
  }

  .veylique-footer-social a {
    display: flex;
    align-items: center;
    color: rgba(255, 250, 247, 0.5);
    transition: color 180ms ease, transform 180ms ease;
  }

  .veylique-footer-social a:hover {
    transform: translateY(-0.0625rem);
  }

  .veylique-footer-brand {
    position: relative;
    height: clamp(10rem, 22vw, 20rem);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 1rem;
    background: #0a0a08;
  }

  .veylique-footer-brand-text {
    position: relative;
    z-index: 1;
    color: #fff;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: clamp(6rem, 20vw, 18rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    text-transform: uppercase;
    user-select: none;
    white-space: nowrap;
  }

  .veylique-footer-brand-media {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.72;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .veylique-footer[data-veylique-footer] .veylique-footer-col,
  .veylique-footer[data-veylique-footer] .veylique-footer-brand-text {
    transform: translateY(1rem);
  }

  .veylique-footer.is-visible .veylique-footer-col,
  .veylique-footer.is-visible .veylique-footer-brand-text {
    animation: veyliqueFooterReveal 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .veylique-footer.is-visible .veylique-footer-col:nth-child(2) {
    animation-delay: 100ms;
  }

  .veylique-footer.is-visible .veylique-footer-col:nth-child(3) {
    animation-delay: 180ms;
  }

  .veylique-footer.is-visible .veylique-footer-brand-text {
    animation-delay: 260ms;
  }

  @keyframes veyliqueFooterReveal {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 896px) {
    .veylique-footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .veylique-footer-col--cta {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 576px) {
    .veylique-footer-main {
      padding: 3rem 0 2.5rem;
    }

    .veylique-footer-inner {
      width: min(100% - 2.5rem, 92rem);
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .veylique-footer-brand-text {
      font-size: clamp(3.5rem, 15vw, 7rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .veylique-footer *,
    .veylique-footer.is-visible * {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline", "default": "Discover your next favourite outfit. Shop today." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop collection" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "text", "id": "copy_suffix", "label": "Copyright suffix", "default": "Women's Fashion" },
    { "type": "text", "id": "payment_label", "label": "Payment icons label", "default": "Accepted payment methods" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "t:labels.show_payment_icons", "default": true },
    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu", "label": "t:labels.menu", "default": "footer" },
    { "type": "text", "id": "menu_label", "label": "Menu label", "default": "Footer navigation" },
    { "type": "link_list", "id": "legal_menu", "label": "Legal menu" },
    { "type": "text", "id": "legal_label", "label": "Legal label", "default": "Legal" },
    { "type": "header", "content": "Connect" },
    { "type": "text", "id": "connect_heading", "label": "Heading", "default": "Connect" },
    { "type": "textarea", "id": "address", "label": "Address", "default": "Modern wardrobe notes, launches, and care." },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@veylique.com" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter signup", "default": true },
    { "type": "text", "id": "newsletter_label", "label": "Newsletter label", "default": "Newsletter" },
    { "type": "text", "id": "newsletter_placeholder", "label": "Newsletter placeholder", "default": "Email address" },
    { "type": "text", "id": "newsletter_button_label", "label": "Newsletter button label", "default": "Subscribe" },
    { "type": "text", "id": "newsletter_success", "label": "Newsletter success message", "default": "Thanks for subscribing." },
    { "type": "header", "content": "Social links" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "instagram_label", "label": "Instagram label", "default": "Instagram" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "text", "id": "tiktok_label", "label": "TikTok label", "default": "TikTok" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL" },
    { "type": "text", "id": "pinterest_label", "label": "Pinterest label", "default": "Pinterest" },
    { "type": "header", "content": "Brand panel" },
    { "type": "text", "id": "brand_text", "label": "Brand text", "default": "Veylique" },
    { "type": "image_picker", "id": "brand_image", "label": "Brand texture image" }
  ]
}
{% endschema %}
