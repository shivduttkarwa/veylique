<section class="veylique-page veylique-section" aria-labelledby="VeyliqueTestimonialsTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueTestimonialsTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        <figure class="veylique-quote-card" {{ block.shopify_attributes }}>
          <blockquote class="veylique-text">{{ block.settings.quote }}</blockquote>
          <figcaption class="veylique-card-title">
            {{ block.settings.name | escape }}
            {% if block.settings.location != blank %}
              <span class="veylique-card-sub">{{ block.settings.location | escape }}</span>
            {% endif %}
          </figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-testimonials.name",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-testimonials.settings.kicker.label",
      "default": "Customer stories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-testimonials.settings.heading.label",
      "default": "Loved for fit, ease, and detail"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-testimonials.settings.text.label",
      "default": "Add social proof that feels specific and useful."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.veylique-testimonials.settings.columns_desktop.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.veylique-testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "quote",
          "label": "t:sections.veylique-testimonials.blocks.testimonial.settings.quote.label",
          "default": "Veylique makes getting dressed feel effortless. Every piece feels considered."
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.veylique-testimonials.blocks.testimonial.settings.name.label",
          "default": "Ananya R."
        },
        {
          "type": "text",
          "id": "location",
          "label": "t:sections.veylique-testimonials.blocks.testimonial.settings.location.label",
          "default": "Mumbai"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-testimonials.presets.name",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Priya M.",
            "location": "Bengaluru",
            "quote": "The fabrics are soft, the cuts are easy, and the styling feels grown-up without feeling stiff."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Kavya S.",
            "location": "Delhi",
            "quote": "I bought one dress for travel and now reach for it every week."
          }
        }
      ]
    }
  ]
}
{% endschema %}
