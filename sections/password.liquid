{% comment %}
  Password landing — shown when the store is password-protected.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

<section class="veylique-password full-width">
  <div class="veylique-password__inner">
    <p class="veylique-kicker veylique-password__eyebrow">{{ 'password.eyebrow' | t }}</p>
    <h1 class="veylique-password__brand">{{ shop.name }}</h1>

    {%- if shop.password_message != blank -%}
      <div class="veylique-password__message veylique-text">{{ shop.password_message }}</div>
    {%- else -%}
      <p class="veylique-password__message veylique-text">{{ 'password.tagline' | t }}</p>
    {%- endif -%}

    {% form 'storefront_password', class: 'veylique-password__form' %}
      {%- if form.errors -%}
        <p class="veylique-password__error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <label for="password-input" class="visually-hidden">{{ 'password.password' | t }}</label>
      <div class="veylique-password__field">
        <input
          type="password"
          name="password"
          id="password-input"
          placeholder="{{ 'password.password' | t }}"
          autocomplete="current-password"
        >
        <button type="submit" class="veylique-button veylique-button--solid">{{ 'password.enter' | t }}</button>
      </div>
    {% endform %}

    <p class="veylique-password__admin">
      {{ 'password.admin_link_html' | t: link: shop.url }}
    </p>
  </div>
</section>

{% stylesheet %}
  .veylique-password {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: clamp(2rem, 6vw, 4rem);
    background:
      radial-gradient(60rem 40rem at 80% -10%, rgba(200, 149, 30, 0.08), transparent 60%),
      var(--veylique-color-background, #fff);
  }
  .veylique-password__inner {
    width: min(100%, 34rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .veylique-password__eyebrow { margin: 0 0 1.25rem; }
  .veylique-password__brand {
    margin: 0 0 1rem;
    font-family: var(--veylique-font-heading);
    font-size: clamp(2.75rem, 9vw, 5rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--veylique-color-foreground);
  }
  .veylique-password__message { max-width: 30rem; margin-bottom: 2.25rem; }
  .veylique-password__message > *:last-child { margin-bottom: 0; }

  .veylique-password__form { width: min(100%, 26rem); }
  .veylique-password__field {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--veylique-color-surface, #fff);
    border: var(--veylique-border-width) solid var(--veylique-color-border);
    border-radius: var(--veylique-radius-pill);
    padding: 0.375rem 0.375rem 0.375rem 1.25rem;
  }
  .veylique-password__field input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    padding: 0.85rem 0.25rem;
    font: inherit;
    color: var(--veylique-color-foreground);
  }
  .veylique-password__field input:focus { outline: none; }
  .veylique-password__field .veylique-button { flex: 0 0 auto; }
  .veylique-password__error {
    margin: 0 0 1rem;
    color: #b42318;
    font-family: var(--veylique-font-body);
    font-size: 0.875rem;
  }
  .veylique-password__admin {
    margin: 1.75rem 0 0;
    color: var(--veylique-color-muted);
    font-family: var(--veylique-font-body);
    font-size: 0.8125rem;
  }
  .veylique-password__admin a { color: var(--veylique-color-foreground); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
