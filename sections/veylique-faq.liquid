<section class="veylique-page veylique-section" data-veylique-faq aria-labelledby="VeyliqueFaqTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueFaqTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        {% liquid
          assign question_id = 'VeyliqueFaqQuestion-' | append: section.id | append: '-' | append: forloop.index
          assign answer_id = 'VeyliqueFaqAnswer-' | append: section.id | append: '-' | append: forloop.index
        %}
        <div class="veylique-faq-item{% if forloop.first %} is-open{% endif %}" {{ block.shopify_attributes }}>
          <button
            id="{{ question_id }}"
            class="veylique-faq-button"
            type="button"
            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="{{ answer_id }}"
            data-veylique-faq-button
          >
            <span>{{ block.settings.question | escape }}</span>
            <span aria-hidden="true">+</span>
          </button>
          <div id="{{ answer_id }}" class="veylique-faq-answer" role="region" aria-labelledby="{{ question_id }}">
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Help desk" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Everything shoppers need before checkout, from fit to delivery and easy exchanges." },
    { "type": "range", "id": "columns_desktop", "label": "Columns on desktop", "min": 1, "max": 3, "step": 1, "default": 3 }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does delivery take?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Most orders ship within 24-48 hours. Standard delivery usually arrives in 3-6 business days.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question", "settings": { "question": "Can I exchange or return an item?", "answer": "<p>Yes. You can request an exchange or return within 7 days of delivery when the item is unused and has original tags.</p>" } },
        { "type": "question", "settings": { "question": "How do I choose the right size?", "answer": "<p>Compare the product size guide with a garment you already love. If you are between sizes, choose the larger size for a relaxed fit.</p>" } }
      ]
    }
  ]
}
{% endschema %}
