{% liquid
  assign slide_blocks = section.blocks | where: 'type', 'slide'
  assign category_blocks = section.blocks | where: 'type', 'link'
  assign fallback_image = blank
  assign fallback_alt = section.settings.heading | strip_html
  assign initial_label = 'New'

  if slide_blocks.size > 0
    for block in slide_blocks limit: 5
      if forloop.first and block.settings.label != blank
        assign initial_label = block.settings.label
      endif

      if fallback_image == blank and block.settings.image != blank
        assign fallback_image = block.settings.image
        if block.settings.label != blank
          assign fallback_alt = block.settings.label
        endif
      endif
    endfor
  elsif section.settings.label_1 != blank
    assign initial_label = section.settings.label_1
  endif
%}

<section
  class="veylique-page veylique-home-hero veylique-full-width"
  id="VeyliqueHero-{{ section.id }}"
  aria-labelledby="VeyliqueHeroTitle-{{ section.id }}"
  data-veylique-hero
>
  <div class="veylique-home-hero__fallback">
    {% render 'veylique-responsive-image',
      image: fallback_image,
      fallback: 'hero-1.webp',
      class: 'veylique-media',
      alt: fallback_alt,
      loading: 'eager',
      width: 2400,
      height: 1600
    %}
  </div>

  <div class="veylique-home-hero__canvas-wrap" aria-hidden="true">
    <canvas class="veylique-home-hero__canvas" data-veylique-hero-canvas></canvas>
  </div>

  <div class="veylique-home-hero__content">
    <p class="veylique-home-hero__label" data-veylique-hero-label>
      {{ initial_label | escape }}
    </p>

    {% if category_blocks.size > 0 %}
      <nav class="veylique-home-hero__subtitles" aria-label="{{ section.settings.category_label | escape }}">
        {% for block in category_blocks limit: 3 %}
          <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
            {{ block.settings.label | escape }}
          </a>
        {% endfor %}
      </nav>
    {% endif %}

    <h1 id="VeyliqueHeroTitle-{{ section.id }}" class="veylique-home-hero__title">
      {{ section.settings.heading }}
    </h1>

    {% if section.settings.button_label != blank %}
      <div class="veylique-home-hero__cta">
        <a class="veylique-home-hero__button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {% endif %}
  </div>

  <button type="button" class="veylique-home-hero__scroll" aria-label="{{ section.settings.scroll_label | escape }}" data-veylique-scroll-down>
    <span></span>
    <span></span>
    <span></span>
  </button>

  <script type="application/json" data-veylique-hero-config>
    {
      "images": [
        {% if slide_blocks.size > 0 %}
          {% for block in slide_blocks limit: 5 %}
            {% liquid
              capture fallback_asset
                echo 'hero-' | append: forloop.index | append: '.webp'
              endcapture

              capture slide_url
                if block.settings.image != blank
                  echo block.settings.image | image_url: width: 2400
                else
                  echo fallback_asset | strip | asset_url
                endif
              endcapture
            %}
            {{ slide_url | strip | json }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% else %}
          {{ 'hero-1.webp' | asset_url | json }},
          {{ 'hero-2.webp' | asset_url | json }},
          {{ 'hero-3.webp' | asset_url | json }},
          {{ 'hero-4.webp' | asset_url | json }},
          {{ 'hero-5.webp' | asset_url | json }}
        {% endif %}
      ],
      "labels": [
        {% if slide_blocks.size > 0 %}
          {% for block in slide_blocks limit: 5 %}
            {{ block.settings.label | default: initial_label | json }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% else %}
          {{ section.settings.label_1 | default: 'New' | json }},
          {{ section.settings.label_2 | default: 'Bold' | json }},
          {{ section.settings.label_3 | default: 'Chic' | json }},
          {{ section.settings.label_4 | default: 'Effortless' | json }},
          {{ section.settings.label_5 | default: 'Fresh' | json }}
        {% endif %}
      ],
      "slideDuration": {{ section.settings.slide_duration | times: 1000 | json }},
      "transitionDuration": {{ section.settings.transition_duration | times: 1000 | json }}
    }
  </script>
</section>

{% schema %}
{
  "name": "t:sections.veylique-hero.name",
  "tag": "section",
  "class": "shopify-section--veylique-hero",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.veylique-hero.settings.content__0"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.veylique-hero.settings.heading.label",
      "default": "Veylique"
    },
    {
      "type": "text",
      "id": "category_label",
      "label": "t:sections.veylique-hero.settings.category_label.label",
      "default": "Featured categories"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-hero.settings.button_label.label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-hero.settings.button_link.label"
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "t:sections.veylique-hero.settings.scroll_label.label",
      "default": "Scroll down"
    },
    {
      "type": "header",
      "content": "t:sections.veylique-hero.settings.content__1"
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "t:sections.veylique-hero.settings.slide_duration.label",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "transition_duration",
      "label": "t:sections.veylique-hero.settings.transition_duration.label",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.veylique-hero.blocks.slide.name",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-hero.blocks.slide.settings.image.label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.veylique-hero.blocks.slide.settings.label.label",
          "default": "New"
        }
      ]
    },
    {
      "type": "link",
      "name": "t:sections.veylique-hero.blocks.link.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.veylique-hero.blocks.link.settings.label.label",
          "default": "Dresses"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.veylique-hero.blocks.link.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-hero.presets.name",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "label": "New"
          }
        },
        {
          "type": "slide",
          "settings": {
            "label": "Bold"
          }
        },
        {
          "type": "slide",
          "settings": {
            "label": "Chic"
          }
        },
        {
          "type": "slide",
          "settings": {
            "label": "Effortless"
          }
        },
        {
          "type": "slide",
          "settings": {
            "label": "Fresh"
          }
        },
        {
          "type": "link",
          "settings": {
            "label": "Dresses"
          }
        },
        {
          "type": "link",
          "settings": {
            "label": "Ethnic wear"
          }
        },
        {
          "type": "link",
          "settings": {
            "label": "Western wear"
          }
        }
      ]
    }
  ]
}
{% endschema %}
