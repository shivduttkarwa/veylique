<section class="veylique-about-materials-section full-width" data-veylique-about-materials>
  <div class="veylique-section-intro veylique-section-intro-js">
    <div class="veylique-container-wide container-fluid">
      <div class="row">
        <div class="col-12 col-xl-10">
          {%- if section.settings.eyebrow != blank -%}
            <span class="veylique-eyebrow">{{ section.settings.eyebrow | escape }}</span>
          {%- endif -%}
          <h2 class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
          {%- if section.settings.text != blank -%}
            <p class="veylique-section-desc">{{ section.settings.text | escape }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <div class="veylique-about-materials">
    <div class="veylique-about-ing-inner">
      <div class="veylique-about-ing-grid" data-veylique-about-ing-grid>
        {%- for block in section.blocks -%}
          {%- if block.type == 'material' -%}
            <div class="veylique-about-ing-card veylique-about-ing-card-reveal-js" {{ block.shopify_attributes }}>
              {% render 'veylique-responsive-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                class: 'veylique-about-ing-img',
                alt: block.settings.name,
                width: 900,
                height: 1100
              %}
              {%- if block.settings.tag != blank -%}
                <span class="veylique-about-ing-tag">{{ block.settings.tag | escape }}</span>
              {%- endif -%}
              <div class="veylique-about-ing-body">
                <h3 class="veylique-about-ing-name">{{ block.settings.name | escape }}</h3>
                <p class="veylique-about-ing-desc">{{ block.settings.desc | escape }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- assign check_blocks = section.blocks | where: 'type', 'check' -%}
      {%- if check_blocks.size > 0 -%}
        <ul class="veylique-about-check-list">
          {%- for block in check_blocks -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .veylique-about-materials {
    background: #fff;
    padding: 0 clamp(1.5rem, 6vw, 6rem) clamp(4rem, 8vw, 6rem);
  }
  .veylique-about-ing-inner {
    max-width: 75rem;
    margin-inline: auto;
  }
  .veylique-about-ing-grid {
    display: flex;
    gap: 0.75rem;
    height: clamp(26rem, 60vh, 34rem);
  }
  .veylique-about-ing-card {
    position: relative;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    border-radius: var(--mustard-radius);
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: flex 0.65s cubic-bezier(0.7, 0, 0.3, 1);
  }
  .veylique-about-ing-grid:hover .veylique-about-ing-card:hover { flex: 2.2; }
  .veylique-about-ing-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.12);
    transition: transform 0.65s cubic-bezier(0.7, 0, 0.3, 1);
  }
  .veylique-about-ing-card:hover .veylique-about-ing-img { transform: scale(1); }
  .veylique-about-ing-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14, 11, 10, 0.25) 0%, rgba(14, 11, 10, 0) 38%, rgba(14, 11, 10, 0.78) 100%);
    pointer-events: none;
  }
  .veylique-about-ing-tag {
    position: relative;
    z-index: 1;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    padding: 0.5rem 0.875rem;
    border: 0.0625rem solid rgba(255, 250, 247, 0.4);
    border-radius: 999px;
    background: rgba(14, 11, 10, 0.25);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    font-family: "Clash Display", Inter, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: #faf6ec;
  }
  .veylique-about-ing-body { position: relative; z-index: 1; }
  .veylique-about-ing-name {
    margin: 0;
    font-family: "Clash Display", Inter, sans-serif;
    font-size: clamp(1.375rem, 2.4vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #faf6ec;
  }
  .veylique-about-ing-desc {
    margin: 0;
    max-width: 24rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(255, 250, 247, 0.85);
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    transform: translateY(0.75rem);
    transition:
      max-height 0.65s cubic-bezier(0.7, 0, 0.3, 1),
      margin-top 0.65s cubic-bezier(0.7, 0, 0.3, 1),
      opacity 0.45s ease,
      transform 0.65s cubic-bezier(0.7, 0, 0.3, 1);
  }
  .veylique-about-ing-card:hover .veylique-about-ing-desc {
    max-height: 10rem;
    opacity: 1;
    transform: translateY(0);
    margin-top: 0.875rem;
    transition-delay: 0.12s;
  }
  @media (hover: none) {
    .veylique-about-ing-img { transform: none; }
    .veylique-about-ing-desc { max-height: none; opacity: 1; transform: none; margin-top: 0.875rem; }
  }
  @media (max-width: 767px) {
    .veylique-about-ing-grid { flex-direction: column; height: auto; }
    .veylique-about-ing-card { flex: none; min-height: 16rem; justify-content: flex-end; gap: 1.25rem; }
  }

  .veylique-about-check-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .veylique-about-check-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.6875rem 1.25rem;
    border: 0.0625rem solid var(--mustard-border);
    border-radius: 999px;
    background: var(--mustard-bg);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--mustard-text);
  }
  .veylique-about-check-list li::before {
    content: '';
    width: 0.4375rem;
    height: 0.4375rem;
    border-radius: 50%;
    background: var(--mustard-accent);
    flex-shrink: 0;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function whenReady(cb) {
      var n = 0;
      (function check() {
        if (window.gsap && window.ScrollTrigger) { cb(); return; }
        if (n++ > 200) return;
        requestAnimationFrame(check);
      })();
    }
    function initIng(root) {
      var sections = root.querySelectorAll('[data-veylique-about-materials]');
      sections.forEach(function (section) {
        if (section.dataset.veyliqueIngReady === 'true') return;
        section.dataset.veyliqueIngReady = 'true';
        window.gsap.registerPlugin(window.ScrollTrigger);

        var grid = section.querySelector('[data-veylique-about-ing-grid]');
        var cards = Array.prototype.slice.call(section.querySelectorAll('.veylique-about-ing-card-reveal-js'));
        if (!grid || !cards.length) return;

        window.gsap.set(cards, { autoAlpha: 0, y: 28 });
        window.ScrollTrigger.create({
          trigger: grid,
          start: 'top 80%',
          once: true,
          onEnter: function () {
            window.gsap.to(cards, { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out', stagger: 0.14 });
          }
        });
      });
    }

    function boot(root) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      whenReady(function () { initIng(root); });
    }
    if (document.readyState === 'complete') {
      boot(document);
    } else {
      document.addEventListener('DOMContentLoaded', function () { boot(document); });
    }
    document.addEventListener('shopify:section:load', function (event) { boot(event.target); });
  })();
{% endjavascript %}

{% schema %}
