{% doc %}
  Renders one of the Veylique services icons by name.
  @param {string} [icon] - One of: styling, wardrobe, occasion, fit, bridal, virtual.
  @example
  {% render 'veylique-svc-icon', icon: block.settings.icon %}
{% enddoc %}
{% case icon %}
  {% when 'styling' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a7 7 0 0 1 7 7c0 2.5-1.4 4.1-2.6 5.4-.8.9-1.4 1.9-1.4 3.1h-6c0-1.2-.6-2.2-1.4-3.1C6.4 14.1 5 12.5 5 10a7 7 0 0 1 7-7Z"/><path d="M9.5 21.5h5"/></svg>
  {% when 'wardrobe' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c-4 0-7-3-7-7 0-5 5-8.5 7-11 2 2.5 7 6 7 11 0 4-3 7-7 7Z"/><path d="M12 17a3.5 3.5 0 0 1-3.5-3.5"/></svg>
  {% when 'occasion' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v2M12 18v2M4 12H6M18 12h2M6.3 6.3l1.4 1.4M16.3 16.3l1.4 1.4M6.3 17.7l1.4-1.4M16.3 7.7l1.4-1.4"/><circle cx="12" cy="12" r="3.5"/></svg>
  {% when 'fit' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="6.5"/><path d="M21 21l-4.5-4.5"/><path d="M8.5 11a2.5 2.5 0 0 1 2.5-2.5"/></svg>
  {% when 'bridal' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.8 4.6L18 9l-4.2 1.4L12 15l-1.8-4.6L6 9l4.2-1.4L12 3Z"/><path d="M18.5 15l.9 2.1 2.1.9-2.1.9-.9 2.1-.9-2.1-2.1-.9 2.1-.9.9-2.1Z"/></svg>
  {% when 'virtual' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="13" height="12" rx="2.5"/><path d="M16 10.5l5-2.5v8l-5-2.5"/></svg>
  {% else %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a7 7 0 0 1 7 7c0 2.5-1.4 4.1-2.6 5.4-.8.9-1.4 1.9-1.4 3.1h-6c0-1.2-.6-2.2-1.4-3.1C6.4 14.1 5 12.5 5 10a7 7 0 0 1 7-7Z"/><path d="M9.5 21.5h5"/></svg>
{% endcase %}
