<section class="veylique-page veylique-sale veylique-full-width" aria-labelledby="VeyliqueBannerTitle-{{ section.id }}">
  <div class="veylique-sale__media">
    {% render 'veylique-responsive-image',
      image: section.settings.image,
      fallback: section.settings.fallback,
      class: 'veylique-media',
      alt: section.settings.heading,
      width: 2400,
      height: 1600
    %}
  </div>
  <div class="veylique-sale__content">
    <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
    <h2 id="VeyliqueBannerTitle-{{ section.id }}" class="veylique-title">{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}
      <p class="veylique-text" style="color: rgba(255,255,255,0.78); max-width: 34rem;">{{ section.settings.text }}</p>
    {% endif %}
    {% if section.settings.button_label != blank %}
      <a class="veylique-button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
        {{ section.settings.button_label | escape }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-image-banner.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.veylique-image-banner.settings.image.label"
    },
    {
      "type": "text",
      "id": "fallback",
      "label": "t:sections.veylique-image-banner.settings.fallback.label",
      "default": "hero-1.webp"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-image-banner.settings.kicker.label",
      "default": "Ready when you are"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.veylique-image-banner.settings.heading.label",
      "default": "For every size, mood, and plan"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "t:sections.veylique-image-banner.settings.text.label",
      "default": "Bring shoppers into a focused collection, sale, or seasonal story."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-image-banner.settings.button_label.label",
      "default": "Shop all products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-image-banner.settings.button_link.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-image-banner.presets.name"
    }
  ]
}
{% endschema %}
