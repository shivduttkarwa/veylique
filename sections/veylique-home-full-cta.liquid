{% liquid
  assign cta_bg = section.settings.fallback | default: 'hero-1.webp' | asset_url
  assign cta_bg_mobile = section.settings.mobile_fallback | default: section.settings.fallback | default: 'hero-1.webp' | asset_url

  if section.settings.image != blank
    assign cta_bg = section.settings.image | image_url: width: 2400
  endif

  if section.settings.mobile_image != blank
    assign cta_bg_mobile = section.settings.mobile_image | image_url: width: 1400
  endif
%}

<section class="veylique-fullcta full-width" aria-label="{{ section.settings.aria_label | escape }}" style="--cta-bg: url('{{ cta_bg }}'); --cta-bg-mobile: url('{{ cta_bg_mobile }}');">
  <div class="veylique-fullcta-overlay"></div>
  <div class="veylique-fullcta-inner">
    {%- if section.settings.label != blank -%}
      <p class="veylique-fullcta-label veylique-reveal-js veylique-reveal--static-js">{{ section.settings.label | escape }}</p>
    {%- endif -%}
    <h2 class="veylique-fullcta-heading veylique-reveal-js veylique-reveal--static-js">{{ section.settings.heading }}</h2>
    <div class="veylique-fullcta-btns">
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="veylique-fullcta-btn veylique-reveal-js veylique-reveal--static-js" data-veylique-delay="0.15">
        <span>{{ section.settings.button_label }}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      {%- if section.settings.button2_label != blank -%}
        <a href="{{ section.settings.button2_link | default: '#' }}" class="veylique-fullcta-btn veylique-fullcta-btn--outline veylique-reveal-js veylique-reveal--static-js" data-veylique-delay="0.28">
          <span>{{ section.settings.button2_label }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-home-full-cta.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "t:sections.veylique-home-full-cta.settings.aria_label.label",
      "default": "Shop all products"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.veylique-home-full-cta.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:sections.veylique-home-full-cta.settings.mobile_image.label"
    },
    {
      "type": "text",
      "id": "fallback",
      "label": "t:sections.veylique-home-full-cta.settings.fallback.label",
      "default": "hero-1.webp"
    },
    {
      "type": "text",
      "id": "mobile_fallback",
      "label": "t:sections.veylique-home-full-cta.settings.mobile_fallback.label",
      "default": "hero-1.webp"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.veylique-home-full-cta.settings.label.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.veylique-home-full-cta.settings.heading.label",
      "default": "For <em>every</em> size."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-home-full-cta.settings.button_label.label",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-home-full-cta.settings.button_link.label"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "t:sections.veylique-home-full-cta.settings.button2_label.label"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "t:sections.veylique-home-full-cta.settings.button2_link.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-full-cta.presets.name"
    }
  ]
}
{% endschema %}
