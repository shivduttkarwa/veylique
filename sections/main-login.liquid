{% comment %}
  Customer login — classic customer accounts. Pairs the sign-in form with a
  "forgot password" reveal. The recover form is captured first so its posted
  state (success / errors) is known before the panes render, letting a CSS-only
  :target toggle handle user clicks while server state forces the right pane
  after a reload — no JavaScript required.
{% endcomment %}

{%- comment -%} Capture recover form first to read its posted state. {%- endcomment -%}
{%- capture recover_form -%}
  {% form 'recover_customer_password', class: 'vq-form' %}
    {%- if form.posted_successfully? -%}{%- assign recover_success = true -%}{%- endif -%}
    {%- if form.errors -%}
      {%- assign recover_open = true -%}
      <div class="vq-alert vq-alert--error" role="alert">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div class="vq-field">
      <label class="vq-label" for="RecoverEmail-{{ section.id }}">{{ 'customers.login.email' | t }}</label>
      <input
        type="email"
        class="vq-input"
        id="RecoverEmail-{{ section.id }}"
        name="email"
        autocomplete="email"
        autocapitalize="off"
        spellcheck="false"
        placeholder="{{ section.settings.email_placeholder | escape }}"
        required
      >
    </div>

    <button type="submit" class="veylique-btn btn-black veylique-btn--block">{{ 'customers.recover.submit' | t }}</button>
  {% endform %}
{%- endcapture -%}

<section class="vq-auth" aria-labelledby="LoginTitle-{{ section.id }}">
  {% render 'veylique-auth-aside',
    image: section.settings.image,
    fallback: section.settings.fallback,
    eyebrow: section.settings.aside_eyebrow,
    heading: section.settings.aside_heading,
    text: section.settings.aside_text
  %}

  <div class="vq-auth__panel">
    <div class="vq-auth__card">
      <div class="vq-auth__panes{% if recover_open %} is-recover-open{% endif %}" id="recover">
        {%- comment -%} ---- Sign in ---- {%- endcomment -%}
        <div class="vq-auth__pane vq-auth__pane--login">
          <div class="vq-auth__head">
            <span class="vq-auth__eyebrow">{{ section.settings.eyebrow | escape }}</span>
            <h1 id="LoginTitle-{{ section.id }}" class="vq-auth__title">{{ section.settings.heading | escape }}</h1>
            {% if section.settings.subheading != blank %}
              <p class="vq-auth__subtitle">{{ section.settings.subheading | escape }}</p>
            {% endif %}
          </div>

          {%- if recover_success -%}
            <div class="vq-alert vq-alert--success" role="status">
              <p>{{ 'customers.recover.success' | t }}</p>
            </div>
          {%- endif -%}

          {% form 'customer_login', class: 'vq-form' %}
            {% if form.errors %}
              <div class="vq-alert vq-alert--error" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="vq-field">
              <label class="vq-label" for="CustomerEmail-{{ section.id }}">{{ 'customers.login.email' | t }}</label>
              <input
                type="email"
                class="vq-input"
                id="CustomerEmail-{{ section.id }}"
                name="customer[email]"
                autocomplete="email"
                autocapitalize="off"
                spellcheck="false"
                placeholder="{{ section.settings.email_placeholder | escape }}"
                required
              >
            </div>

            <div class="vq-field">
              <label class="vq-label" for="CustomerPassword-{{ section.id }}">
                {{ 'customers.login.password' | t }}
                <span class="vq-label__hint"><a href="#recover">{{ 'customers.login.forgot' | t }}</a></span>
              </label>
              <input
                type="password"
                class="vq-input"
                id="CustomerPassword-{{ section.id }}"
                name="customer[password]"
                autocomplete="current-password"
                placeholder="{{ section.settings.password_placeholder | escape }}"
                required
              >
            </div>

            <button type="submit" class="veylique-btn btn-black veylique-btn--block">{{ 'customers.login.submit' | t }}</button>
          {% endform %}

          <p class="vq-auth__foot">
            {{ 'customers.login.no_account' | t }}
            <a href="{{ routes.account_register_url }}">{{ 'customers.login.create' | t }}</a>
          </p>
        </div>

        {%- comment -%} ---- Recover password ---- {%- endcomment -%}
        <div class="vq-auth__pane vq-auth__pane--recover">
          <div class="vq-auth__head">
            <span class="vq-auth__eyebrow">{{ 'customers.recover.eyebrow' | t }}</span>
            <h2 class="vq-auth__title">{{ 'customers.recover.title' | t }}</h2>
            <p class="vq-auth__subtitle">{{ 'customers.recover.subtitle' | t }}</p>
          </div>

          {{ recover_form }}

          <p class="vq-auth__foot">
            <a href="#login">{{ 'customers.recover.back' | t }}</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    { "type": "header", "content": "t:sections.main-login.settings.form_header.content" },
    { "type": "text", "id": "eyebrow", "label": "t:sections.main-login.settings.eyebrow.label", "default": "Account" },
    { "type": "text", "id": "heading", "label": "t:sections.main-login.settings.heading.label", "default": "Welcome back" },
    { "type": "text", "id": "subheading", "label": "t:sections.main-login.settings.subheading.label", "default": "Sign in to view orders, track shipments and manage your details." },
    { "type": "text", "id": "email_placeholder", "label": "t:sections.main-login.settings.email_placeholder.label", "default": "you@example.com" },
    { "type": "text", "id": "password_placeholder", "label": "t:sections.main-login.settings.password_placeholder.label", "default": "••••••••" },
    { "type": "header", "content": "t:sections.main-login.settings.aside_header.content" },
    { "type": "image_picker", "id": "image", "label": "t:sections.main-login.settings.image.label" },
    { "type": "text", "id": "fallback", "label": "t:sections.main-login.settings.fallback.label", "default": "hero-3.webp" },
    { "type": "text", "id": "aside_eyebrow", "label": "t:sections.main-login.settings.aside_eyebrow.label", "default": "Veylique" },
    { "type": "text", "id": "aside_heading", "label": "t:sections.main-login.settings.aside_heading.label", "default": "Everyday polish, effortlessly yours." },
    { "type": "text", "id": "aside_text", "label": "t:sections.main-login.settings.aside_text.label", "default": "Sign in to a wardrobe built around comfort, confident silhouettes and quiet luxury." }
  ]
}
{% endschema %}
