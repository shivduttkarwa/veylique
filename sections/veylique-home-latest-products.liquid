<div class="veylique-section-intro veylique-section-intro-js veylique-latest-intro full-width">
  <div class="veylique-container-wide">
    <div class="row">
      <div class="col-12 col-xl-10">
        <h2 id="VeyliqueLatestTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading }}</h2>
        <p class="veylique-section-desc">{{ section.settings.text }}</p>
      </div>
    </div>
  </div>
</div>

<section class="veylique-latest full-width" aria-labelledby="VeyliqueLatestTitle-{{ section.id }}">
  <div class="veylique-latest-slider-area" data-veylique-card-slider>
    <div class="swiper veylique-latest-swiper" tabindex="0" data-veylique-card-slider-viewport>
      <div class="swiper-wrapper veylique-latest-grid" data-veylique-card-slider-track>
        {% liquid
          assign products_to_show = section.settings.products_to_show
          assign product_collection = section.settings.collection
          assign has_products = false
          if product_collection != blank and product_collection.products.size > 0
            assign has_products = true
          endif
        %}
        {% if has_products %}
          {% for product in product_collection.products limit: products_to_show %}
            <div class="swiper-slide">
              {% render 'veylique-home-product-card', variant: 'latest', product: product %}
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..products_to_show) %}
            <div class="swiper-slide">
              {% render 'veylique-home-product-card', variant: 'latest', placeholder: true %}
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_navigation %}
      <div class="veylique-carousel-nav veylique-latest-nav" aria-label="{{ section.settings.controls_label | escape }}">
        <button class="veylique-carousel-nav-btn veylique-latest-prev" type="button" data-veylique-card-slider-prev aria-label="{{ section.settings.previous_label | escape }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        </button>
        <button class="veylique-carousel-nav-btn veylique-latest-next" type="button" data-veylique-card-slider-next aria-label="{{ section.settings.next_label | escape }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    {% endif %}
  </div>

  {% if section.settings.button_label != blank %}
    <div class="veylique-latest-cta">
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="veylique-btn btn-black">{{ section.settings.button_label }}</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "t:sections.veylique-home-latest-products.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-home-latest-products.settings.heading.label",
      "default": "Latest Products"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-home-latest-products.settings.text.label",
      "default": "Freshly launched styles and seasonal essentials selected for your next outfit."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.veylique-home-latest-products.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 10,
      "label": "t:sections.veylique-home-latest-products.settings.products_to_show.label"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "t:sections.veylique-home-latest-products.settings.show_navigation.label",
      "default": true
    },
    {
      "type": "text",
      "id": "controls_label",
      "label": "t:sections.veylique-home-latest-products.settings.controls_label.label",
      "default": "Latest products carousel controls"
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "t:sections.veylique-home-latest-products.settings.previous_label.label",
      "default": "Previous products"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "t:sections.veylique-home-latest-products.settings.next_label.label",
      "default": "Next products"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.veylique-home-latest-products.settings.button_label.label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.veylique-home-latest-products.settings.button_link.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-home-latest-products.presets.name"
    }
  ]
}
{% endschema %}
