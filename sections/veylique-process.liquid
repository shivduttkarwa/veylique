<section class="veylique-page veylique-section" aria-labelledby="VeyliqueProcessTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueProcessTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid veylique-process-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        <article class="veylique-process-card" {{ block.shopify_attributes }}>
          <h3 class="veylique-card-title">{{ block.settings.heading | escape }}</h3>
          <p class="veylique-text">{{ block.settings.text | escape }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-process.name",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-process.settings.kicker.label",
      "default": "The style ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-process.settings.heading.label",
      "default": "Your everyday edit"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-process.settings.text.label",
      "default": "Four considered steps, one confident look. A complete approach to getting dressed, built around real bodies."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.veylique-process.settings.columns_desktop.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.veylique-process.blocks.column.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.veylique-process.blocks.column.settings.heading.label",
          "default": "Discover"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.veylique-process.blocks.column.settings.text.label",
          "default": "Start with mood, size, routine, and the moments you are dressing for."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-process.presets.name",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "heading": "Discover"
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Fit",
            "text": "Choose silhouettes and fabrics that feel natural through the day."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Style",
            "text": "Build outfits with pieces that repeat, layer, and travel well."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Wear",
            "text": "Keep the final look polished without sacrificing movement."
          }
        }
      ]
    }
  ]
}
{% endschema %}
