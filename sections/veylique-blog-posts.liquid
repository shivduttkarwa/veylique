<section class="veylique-page veylique-section" aria-labelledby="VeyliqueBlogTitle-{{ section.id }}">
  <div class="veylique-container">
    <div class="veylique-section-head">
      <div>
        <p class="veylique-kicker">{{ section.settings.kicker | escape }}</p>
        <h2 id="VeyliqueBlogTitle-{{ section.id }}" class="veylique-section-title">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="veylique-text">{{ section.settings.text | escape }}</p>
    </div>

    <div class="veylique-card-grid" style="--columns: {{ section.settings.columns_desktop }}">
      {% if section.settings.blog != blank and section.settings.blog.articles_count > 0 %}
        {% for article in section.settings.blog.articles limit: section.settings.post_limit %}
          <a class="veylique-article-card" href="{{ article.url }}">
            {% if article.image %}
              <span class="veylique-article-card__media">
                {% render 'veylique-responsive-image', image: article.image, fallback: 'hero-5.webp', class: 'veylique-media', alt: article.title, width: 900 %}
              </span>
            {% endif %}
            <span class="veylique-card-body">
              <span>
                <span class="veylique-card-title">{{ article.title | escape }}</span>
                <span class="veylique-card-sub">{{ article.published_at | date: format: 'abbreviated_date' }}</span>
              </span>
            </span>
          </a>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          <article class="veylique-article-card" {{ block.shopify_attributes }}>
            <span class="veylique-article-card__media">
              {% render 'veylique-responsive-image', image: block.settings.image, fallback: block.settings.fallback, class: 'veylique-media', alt: block.settings.heading, width: 900 %}
            </span>
            <span class="veylique-card-body">
              <span>
                <span class="veylique-card-title">{{ block.settings.heading | escape }}</span>
                <span class="veylique-card-sub">{{ block.settings.meta | escape }}</span>
              </span>
            </span>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.veylique-blog-posts.name",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "t:sections.veylique-blog-posts.settings.kicker.label",
      "default": "Recent stories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.veylique-blog-posts.settings.heading.label",
      "default": "Recent stories"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.veylique-blog-posts.settings.text.label",
      "default": "Style guides, sizing notes, and a look behind the collections."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.veylique-blog-posts.settings.blog.label"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "t:sections.veylique-blog-posts.settings.post_limit.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.veylique-blog-posts.settings.columns_desktop.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "t:sections.veylique-blog-posts.blocks.article.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.veylique-blog-posts.blocks.article.settings.image.label"
        },
        {
          "type": "text",
          "id": "fallback",
          "label": "t:sections.veylique-blog-posts.blocks.article.settings.fallback.label",
          "default": "hero-2.webp"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.veylique-blog-posts.blocks.article.settings.heading.label",
          "default": "The ultimate guide to layering this winter"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "t:sections.veylique-blog-posts.blocks.article.settings.meta.label",
          "default": "Style guide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.veylique-blog-posts.presets.name",
      "blocks": [
        {
          "type": "article",
          "settings": {
            "fallback": "hero-2.webp"
          }
        },
        {
          "type": "article",
          "settings": {
            "heading": "Five ways to style your kurta set",
            "meta": "Style tips",
            "fallback": "hero-3.webp"
          }
        },
        {
          "type": "article",
          "settings": {
            "heading": "How to find your perfect fit",
            "meta": "Guides",
            "fallback": "hero-4.webp"
          }
        }
      ]
    }
  ]
}
{% endschema %}
