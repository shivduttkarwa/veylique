<section class="veylique-testi-section full-width" aria-label="{{ section.settings.aria_label | escape }}" data-veylique-testi>
  <span class="veylique-eyebrow veylique-testi-eyebrow">{{ section.settings.kicker }}</span>

  <div class="veylique-testi-field">
    <div class="veylique-testi-orbit veylique-testi-orbit--left" aria-hidden="true">
      {% for block in section.blocks limit: 3 %}
        <button type="button" class="veylique-testi-bubble{% if forloop.first %} is-active{% endif %}" data-testi-target="{{ forloop.index0 }}" aria-label="Show testimonial from {{ block.settings.name | escape }}" style="--bubble-size: {{ block.settings.bubble_size }}rem; top: {{ block.settings.top }}%; left: {{ block.settings.side_offset }}%; --float-duration: {{ block.settings.float_duration }}s; --float-delay: {{ block.settings.float_delay }}s;">
          {% render 'veylique-responsive-image', image: block.settings.image, fallback: block.settings.fallback, class: '', alt: block.settings.name, width: 260, height: 260 %}
        </button>
      {% endfor %}
    </div>

    <div class="veylique-testi-stage">
      {% for block in section.blocks %}
        <article class="veylique-testi-person{% if forloop.first %} is-active{% endif %}" data-testi-card="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <span class="veylique-testi-avatar">
            {% render 'veylique-responsive-image', image: block.settings.image, fallback: block.settings.fallback, class: '', alt: block.settings.name, width: 260, height: 260 %}
          </span>
          <span class="veylique-testi-mark">
            <svg width="28" height="22" viewBox="0 0 44 34" fill="none" aria-hidden="true"><path d="M18.6 0C8.6 3.3 2 11.4 2 21.2 2 28.3 6.8 34 13.9 34c5.6 0 9.9-4.3 9.9-9.7 0-5.1-3.7-9-8.7-9-1 0-1.9.1-2.4.3C13.8 9.3 18.4 4.2 24.6 1.9L18.6 0zm22.8 0C31.4 3.3 24.8 11.4 24.8 21.2c0 7.1 4.8 12.8 11.9 12.8 5.6 0 9.9-4.3 9.9-9.7 0-5.1-3.7-9-8.7-9-1 0-1.9.1-2.4.3C36.6 9.3 41.2 4.2 47.4 1.9L41.4 0z" fill="currentColor"/></svg>
          </span>
          <p class="veylique-testi-text">{{ block.settings.quote }}</p>
          <span class="veylique-testi-stars">
            {% for star in (1..5) %}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.5l2.9 6.06 6.6.83-4.85 4.6 1.27 6.6L12 17.3l-5.92 3.29 1.27-6.6-4.85-4.6 6.6-.83z"/></svg>
            {% endfor %}
          </span>
          <h3 class="veylique-testi-name">{{ block.settings.name }}<span class="veylique-testi-place">{{ block.settings.place }}</span></h3>
        </article>
      {% endfor %}
    </div>

    <div class="veylique-testi-orbit veylique-testi-orbit--right" aria-hidden="true">
      {% for block in section.blocks offset: 3 limit: 3 %}
        <button type="button" class="veylique-testi-bubble" data-testi-target="{{ forloop.index0 | plus: 3 }}" aria-label="Show testimonial from {{ block.settings.name | escape }}" style="--bubble-size: {{ block.settings.bubble_size }}rem; top: {{ block.settings.top }}%; right: {{ block.settings.side_offset }}%; --float-duration: {{ block.settings.float_duration }}s; --float-delay: {{ block.settings.float_delay }}s;">
          {% render 'veylique-responsive-image', image: block.settings.image, fallback: block.settings.fallback, class: '', alt: block.settings.name, width: 260, height: 260 %}
        </button>
      {% endfor %}
    </div>
  </div>

  <div class="veylique-testi-dots">
    {% for block in section.blocks %}
      <button type="button" class="veylique-testi-dot{% if forloop.first %} is-active{% endif %}" data-testi-target="{{ forloop.index0 }}" aria-label="Testimonial {{ forloop.index }} of {{ section.blocks.size }}"></button>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Veylique testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Customer Stories" },
    { "type": "text", "id": "aria_label", "label": "Accessibility label", "default": "Customer stories" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Avatar" },
        { "type": "text", "id": "fallback", "label": "Fallback asset filename", "default": "hero-1.webp" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The fit was exactly what I hoped for. It feels polished without trying too hard." },
        { "type": "text", "id": "name", "label": "Name", "default": "Anaya R." },
        { "type": "text", "id": "place", "label": "Place", "default": "Mumbai" },
        { "type": "range", "id": "bubble_size", "label": "Bubble size", "min": 3, "max": 6, "step": 0.5, "unit": "rem", "default": 4 },
        { "type": "range", "id": "top", "label": "Vertical position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 10 },
        { "type": "range", "id": "side_offset", "label": "Side position", "min": 0, "max": 30, "step": 1, "unit": "%", "default": 6 },
        { "type": "range", "id": "float_duration", "label": "Float duration", "min": 8, "max": 16, "step": 1, "unit": "s", "default": 10 },
        { "type": "range", "id": "float_delay", "label": "Float delay", "min": 0, "max": 4, "step": 0.5, "unit": "s", "default": 0 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Veylique testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
